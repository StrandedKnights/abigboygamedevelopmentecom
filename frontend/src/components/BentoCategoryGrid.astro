---
---
<section class="py-20 px-6" style="background-color: #0e0e13;">
<div class="max-w-7xl mx-auto">

  <!-- Section header -->
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10">
    <div>
      <p class="font-orbitron text-xs tracking-[0.4em] uppercase mb-2" style="color: #9b5fe0;">Shop per platform</p>
      <h2 class="font-barlow font-black text-5xl md:text-6xl tracking-tight uppercase" style="color: #f9f5fd;">Categorieën</h2>
    </div>
    <a href="#" class="group flex items-center gap-2 font-orbitron text-xs font-bold uppercase tracking-[0.25em] px-4 py-2.5 rounded-sm transition-all" style="background: #1f1f26; border: 1px solid rgba(155,95,224,0.25); color: #9b5fe0;" onmouseover="this.style.background='rgba(155,95,224,0.15)';this.style.borderColor='rgba(155,95,224,0.5)'" onmouseout="this.style.background='#1f1f26';this.style.borderColor='rgba(155,95,224,0.25)'">
      Toon alles
      <span style="color: #acaab1;">(28)</span>
      <span class="material-symbols-outlined text-sm transition-transform duration-200 group-hover:translate-x-1">arrow_forward</span>
    </a>
  </div>

  <!-- Row 1: 3 big platform cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">

    <!-- PlayStation -->
    <div class="relative overflow-hidden group cursor-pointer rounded-sm" style="height: 320px; background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(213,147,255,0.4)'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)'">
      <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBXHNQlv_E8VeFjB4Y00FD6euBZ5AwxtoAxIbTBv0jTBT687l4n6PvPUxhLFCi-AgZTcI1XpTLdM1Jum9Uv0y435x8PVBmi12Ou-bMzrZT3tnZDhf3yHeyv5JVmtToUhBGFQrGgCUJuQKwI79A4vX5qU80-PoD-oV1ZBRlOPaLMLT_gcHoU7LdKJNFc-ch3RrtV6s-Hgcset-vDkZwxe6r8xVyc5S3b9-tC9GyaHvX3C3PNZSKKVaiYMisumJX8dtltHJ1neqgzufw" alt="PlayStation" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:opacity-50 group-hover:scale-105 transition-all duration-700"/>
      <div class="absolute inset-0" style="background: linear-gradient(160deg, transparent 30%, #000 100%);"></div>
      <div class="absolute top-0 left-0 w-1 h-full" style="background: #9b5fe0; box-shadow: 0 0 12px rgba(213,147,255,0.6);"></div>
      <div class="absolute bottom-0 left-0 right-0 p-7">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-2 h-2 rounded-full animate-pulse" style="background: #00FF88;"></div>
          <span class="font-orbitron text-[10px] uppercase tracking-[0.3em]" style="color: #00FF88;">1,240 titels</span>
        </div>
        <h3 class="font-barlow font-black text-4xl uppercase tracking-tight mb-4" style="color: #f9f5fd;">PlayStation</h3>
        <span class="inline-flex items-center gap-1 font-orbitron text-[10px] uppercase tracking-widest px-3 py-2 rounded-sm" style="background: rgba(213,147,255,0.1); border: 1px solid rgba(213,147,255,0.2); color: #9b5fe0;">Bekijken <span class="material-symbols-outlined text-sm">arrow_forward</span></span>
      </div>
    </div>

    <!-- Nintendo -->
    <div class="relative overflow-hidden group cursor-pointer rounded-sm" style="height: 320px; background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(255,75,75,0.4)'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)'">
      <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAKYetgQpr0eqgbQzqIwuFP7_102KNIoTQ0G2krHrRCzEVAbF4SNrty6NcGa4tZX9wxDj4H9T79LnnQs59POIJE0v0CwFbPi1n6HpAFZe3S_vzk2gd7a0N9cj6u9f1CsVmqnnq1EDalT7EKHSsC5QdWTfGN__zrydNxMdPL0ywjQPNBcxo8wEC-SXUz5FgJ0C0l0Ta9F88eypjb5xUFveSIoyeRmqq-qtG85o8_uVVYykbOb34DIy4FvjfMsRZLug9JKUJ4jtTeIX8" alt="Nintendo" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:opacity-50 group-hover:scale-105 transition-all duration-700"/>
      <div class="absolute inset-0" style="background: linear-gradient(160deg, transparent 30%, #000 100%);"></div>
      <div class="absolute top-0 left-0 w-1 h-full" style="background: #ff4b4b; box-shadow: 0 0 12px rgba(255,75,75,0.6);"></div>
      <div class="absolute bottom-0 left-0 right-0 p-7">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-2 h-2 rounded-full animate-pulse" style="background: #00FF88;"></div>
          <span class="font-orbitron text-[10px] uppercase tracking-[0.3em]" style="color: #00FF88;">2,105 titels</span>
        </div>
        <h3 class="font-barlow font-black text-4xl uppercase tracking-tight mb-4" style="color: #f9f5fd;">Nintendo</h3>
        <span class="inline-flex items-center gap-1 font-orbitron text-[10px] uppercase tracking-widest px-3 py-2 rounded-sm" style="background: rgba(255,75,75,0.1); border: 1px solid rgba(255,75,75,0.2); color: #ff4b4b;">Bekijken <span class="material-symbols-outlined text-sm">arrow_forward</span></span>
      </div>
    </div>

    <!-- Xbox -->
    <div class="relative overflow-hidden group cursor-pointer rounded-sm" style="height: 320px; background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(16,124,16,0.4)'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)'">
      <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuD1YIMvcmOS4WueXsKoBILLQ0oAklOnTsAewl-W8rUe5Qg9wBaysqmanN35wRR-dn_077sdAxrzrVeyqBfDeA1e71RK0NzrSrfw1SA1iNk9CHfyMf2QNH39AB9bEsobEGvRZY-KK7Kr4PlQJSOcCgwGt_exBfSR5ApsvHsoRH9YGl-FKfDvEb_Dm4D1MuqGKvE6a8Y2GcS-o9zQbz29nwlRq5S7dah2rCeM-i3eoFIjJaBrbzB93GeIz7JFjrVPxV6KTsNwLqXFqqA" alt="Xbox" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:opacity-50 group-hover:scale-105 transition-all duration-700"/>
      <div class="absolute inset-0" style="background: linear-gradient(160deg, transparent 30%, #000 100%);"></div>
      <div class="absolute top-0 left-0 w-1 h-full" style="background: #107c10; box-shadow: 0 0 12px rgba(16,124,16,0.6);"></div>
      <div class="absolute bottom-0 left-0 right-0 p-7">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-2 h-2 rounded-full animate-pulse" style="background: #00FF88;"></div>
          <span class="font-orbitron text-[10px] uppercase tracking-[0.3em]" style="color: #00FF88;">482 titels</span>
        </div>
        <h3 class="font-barlow font-black text-4xl uppercase tracking-tight mb-4" style="color: #f9f5fd;">Xbox</h3>
        <span class="inline-flex items-center gap-1 font-orbitron text-[10px] uppercase tracking-widest px-3 py-2 rounded-sm" style="background: rgba(16,124,16,0.1); border: 1px solid rgba(16,124,16,0.25); color: #107c10;">Bekijken <span class="material-symbols-outlined text-sm">arrow_forward</span></span>
      </div>
    </div>

  </div>

  <!-- Row 2: 3 smaller subcategory tiles -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

    <!-- Sega -->
    <div class="flex items-center gap-5 p-6 cursor-pointer rounded-sm group transition-all" style="background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(0,84,166,0.4)';this.style.background='#11141a'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)';this.style.background='#131319'">
      <div class="w-12 h-12 rounded-sm flex items-center justify-center flex-shrink-0" style="background: rgba(0,84,166,0.15); border: 1px solid rgba(0,84,166,0.25);">
        <span class="material-symbols-outlined text-2xl" style="color: #0054a6;">token</span>
      </div>
      <div class="flex-1">
        <h4 class="font-orbitron text-base font-black uppercase" style="color: #f9f5fd;">Sega</h4>
        <p class="font-label text-xs mt-0.5" style="color: #76747b;">315 games beschikbaar</p>
      </div>
      <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-opacity" style="color: #0054a6;">arrow_forward</span>
    </div>

    <!-- Handhelds -->
    <div class="flex items-center gap-5 p-6 cursor-pointer rounded-sm group transition-all" style="background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(108,40,145,0.4)';this.style.background='#171219'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)';this.style.background='#131319'">
      <div class="w-12 h-12 rounded-sm flex items-center justify-center flex-shrink-0" style="background: rgba(108,40,145,0.15); border: 1px solid rgba(108,40,145,0.25);">
        <span class="material-symbols-outlined text-2xl" style="color: #6c2891;">smartphone</span>
      </div>
      <div class="flex-1">
        <h4 class="font-orbitron text-base font-black uppercase" style="color: #f9f5fd;">Handhelds</h4>
        <p class="font-label text-xs mt-0.5" style="color: #76747b;">890 games beschikbaar</p>
      </div>
      <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-opacity" style="color: #6c2891;">arrow_forward</span>
    </div>

    <!-- PC Classics -->
    <div class="flex items-center gap-5 p-6 cursor-pointer rounded-sm group transition-all" style="background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(0,255,136,0.3)';this.style.background='#111a15'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)';this.style.background='#131319'">
      <div class="w-12 h-12 rounded-sm flex items-center justify-center flex-shrink-0" style="background: rgba(0,255,136,0.1); border: 1px solid rgba(0,255,136,0.2);">
        <span class="material-symbols-outlined text-2xl" style="color: #00FF88;">desktop_windows</span>
      </div>
      <div class="flex-1">
        <h4 class="font-orbitron text-base font-black uppercase" style="color: #f9f5fd;">PC Classics</h4>
        <p class="font-label text-xs mt-0.5" style="color: #76747b;">154 games beschikbaar</p>
      </div>
      <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-opacity" style="color: #00FF88;">arrow_forward</span>
    </div>

  </div>

</div>
</section>
