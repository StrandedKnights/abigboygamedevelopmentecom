---
---
<section class="py-20 px-6" style="background-color: #0e0e13;">
<div class="max-w-7xl mx-auto">

  <!-- Section header -->
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-10">
    <div class="reveal reveal-left">
      <p class="font-orbitron text-xs tracking-[0.4em] uppercase mb-2" style="color: #d593ff;">Shop per platform</p>
      <h2 class="font-barlow font-black text-5xl md:text-6xl tracking-tight uppercase" style="color: #f9f5fd;">Categorieën</h2>
    </div>
    <a href="#" class="group flex items-center gap-2 font-orbitron text-xs font-bold uppercase tracking-[0.25em] px-4 py-2.5 rounded-sm transition-all" style="background: #1f1f26; border: 1px solid rgba(155,95,224,0.25); color: #d593ff;" onmouseover="this.style.background='rgba(155,95,224,0.15)';this.style.borderColor='rgba(155,95,224,0.5)'" onmouseout="this.style.background='#1f1f26';this.style.borderColor='rgba(155,95,224,0.25)'">
      Toon alles
      <span style="color: #acaab1;">(28)</span>
      <span class="material-symbols-outlined text-sm transition-transform duration-200 group-hover:translate-x-1">arrow_forward</span>
    </a>
  </div>

  <!-- Row 1: 3 big platform cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">

    <!-- PlayStation -->
    <a href="/category/playstation" class="reveal reveal-up relative overflow-hidden group cursor-pointer rounded-sm no-underline [transition-delay:100ms]" style="height: 320px; background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(51,68,255,0.4)'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)'">
      <img src="https://images.unsplash.com/photo-1606144042614-b2417e99c4e3?auto=format&fit=crop&q=80&w=800" alt="PlayStation" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:opacity-50 group-hover:scale-105 transition-all duration-700"/>
      <div class="absolute inset-0" style="background: linear-gradient(160deg, transparent 30%, #000 100%);"></div>
      <div class="absolute top-0 left-0 w-1 h-full" style="background: #3344ff; box-shadow: 0 0 12px rgba(51,68,255,0.6);"></div>
      <div class="absolute bottom-0 left-0 right-0 p-7">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-2 h-2 rounded-full animate-pulse" style="background: #00FF88;"></div>
          <span class="font-orbitron text-[10px] uppercase tracking-[0.3em]" style="color: #00FF88;">1,420 titels</span>
        </div>
        <h3 class="font-barlow font-black text-4xl uppercase tracking-tight mb-4" style="color: #f9f5fd;">PlayStation</h3>
        <span class="inline-flex items-center gap-1 font-orbitron text-[10px] uppercase tracking-widest px-3 py-2 rounded-sm" style="background: rgba(51,68,255,0.1); border: 1px solid rgba(51,68,255,0.2); color: #3344ff;">Bekijken <span class="material-symbols-outlined text-sm">arrow_forward</span></span>
      </div>
    </a>

    <!-- Nintendo -->
    <a href="/category/nintendo" class="reveal reveal-up relative overflow-hidden group cursor-pointer rounded-sm no-underline [transition-delay:200ms]" style="height: 320px; background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(255,75,75,0.4)'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)'">
      <img src="/images/nintendo-console.png" alt="Nintendo" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:opacity-50 group-hover:scale-105 transition-all duration-700"/>
      <div class="absolute inset-0" style="background: linear-gradient(160deg, transparent 30%, #000 100%);"></div>
      <div class="absolute top-0 left-0 w-1 h-full" style="background: #ff4b4b; box-shadow: 0 0 12px rgba(255,75,75,0.6);"></div>
      <div class="absolute bottom-0 left-0 right-0 p-7">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-2 h-2 rounded-full animate-pulse" style="background: #00FF88;"></div>
          <span class="font-orbitron text-[10px] uppercase tracking-[0.3em]" style="color: #00FF88;">2,105 titels</span>
        </div>
        <h3 class="font-barlow font-black text-4xl uppercase tracking-tight mb-4" style="color: #f9f5fd;">Nintendo</h3>
        <span class="inline-flex items-center gap-1 font-orbitron text-[10px] uppercase tracking-widest px-3 py-2 rounded-sm" style="background: rgba(255,75,75,0.1); border: 1px solid rgba(255,75,75,0.2); color: #ff4b4b;">Bekijken <span class="material-symbols-outlined text-sm">arrow_forward</span></span>
      </div>
    </a>

    <!-- Xbox -->
    <a href="/category/xbox" class="reveal reveal-up relative overflow-hidden group cursor-pointer rounded-sm no-underline [transition-delay:300ms]" style="height: 320px; background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(16,124,16,0.4)'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)'">
      <img src="https://images.unsplash.com/photo-1605901309584-818e25960a8f?auto=format&fit=crop&q=80&w=800" alt="Xbox" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:opacity-50 group-hover:scale-105 transition-all duration-700"/>
      <div class="absolute inset-0" style="background: linear-gradient(160deg, transparent 30%, #000 100%);"></div>
      <div class="absolute top-0 left-0 w-1 h-full" style="background: #107c10; box-shadow: 0 0 12px rgba(16,124,16,0.6);"></div>
      <div class="absolute bottom-0 left-0 right-0 p-7">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-2 h-2 rounded-full animate-pulse" style="background: #00FF88;"></div>
          <span class="font-orbitron text-[10px] uppercase tracking-[0.3em]" style="color: #00FF88;">840 titels</span>
        </div>
        <h3 class="font-barlow font-black text-4xl uppercase tracking-tight mb-4" style="color: #f9f5fd;">Xbox</h3>
        <span class="inline-flex items-center gap-1 font-orbitron text-[10px] uppercase tracking-widest px-3 py-2 rounded-sm" style="background: rgba(16,124,16,0.1); border: 1px solid rgba(16,124,16,0.25); color: #107c10;">Bekijken <span class="material-symbols-outlined text-sm">arrow_forward</span></span>
      </div>
    </a>

  </div>

  <!-- Row 2: 3 smaller subcategory tiles -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

    <!-- PlayStation 2 -->
    <a href="/category/ps2" class="reveal reveal-up flex items-center gap-5 p-6 cursor-pointer rounded-sm group transition-all no-underline [transition-delay:400ms]" style="background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(0,55,145,0.4)';this.style.background='#11141a'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)';this.style.background='#131319'">
      <div class="w-12 h-12 rounded-sm flex items-center justify-center flex-shrink-0 transition-transform group-hover:scale-110" style="background: rgba(0,55,145,0.15); border: 1px solid rgba(0,55,145,0.25);">
        <span class="material-symbols-outlined text-2xl" style="color: #003791;">videogame_asset</span>
      </div>
      <div class="flex-1">
        <h4 class="font-orbitron text-base font-black uppercase" style="color: #f9f5fd;">PlayStation 2</h4>
        <p class="font-label text-xs mt-0.5" style="color: #76747b;">450 games beschikbaar</p>
      </div>
      <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-all translate-x-[-10px] group-hover:translate-x-0" style="color: #003791;">arrow_forward</span>
    </a>

    <!-- Nintendo Switch -->
    <a href="/category/switch" class="reveal reveal-up flex items-center gap-5 p-6 cursor-pointer rounded-sm group transition-all no-underline [transition-delay:500ms]" style="background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(230,0,18,0.4)';this.style.background='#191212'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)';this.style.background='#131319'">
      <div class="w-12 h-12 rounded-sm flex items-center justify-center flex-shrink-0 transition-transform group-hover:scale-110" style="background: rgba(230,0,18,0.15); border: 1px solid rgba(230,0,18,0.25);">
        <span class="material-symbols-outlined text-2xl" style="color: #e60012;">sports_esports</span>
      </div>
      <div class="flex-1">
        <h4 class="font-orbitron text-base font-black uppercase" style="color: #f9f5fd;">Nintendo Switch</h4>
        <p class="font-label text-xs mt-0.5" style="color: #76747b;">1,240 games beschikbaar</p>
      </div>
      <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-all translate-x-[-10px] group-hover:translate-x-0" style="color: #e60012;">arrow_forward</span>
    </a>

    <!-- Xbox 360 -->
    <a href="/category/xbox360" class="reveal reveal-up flex items-center gap-5 p-6 cursor-pointer rounded-sm group transition-all no-underline [transition-delay:600ms]" style="background: #131319; border: 1px solid rgba(72,71,77,0.15);" onmouseover="this.style.borderColor='rgba(16,124,16,0.4)';this.style.background='#111a12'" onmouseout="this.style.borderColor='rgba(72,71,77,0.15)';this.style.background='#131319'">
      <div class="w-12 h-12 rounded-sm flex items-center justify-center flex-shrink-0 transition-transform group-hover:scale-110" style="background: rgba(16,124,16,0.15); border: 1px solid rgba(16,124,16,0.25);">
        <span class="material-symbols-outlined text-2xl" style="color: #107c10;">videogame_asset</span>
      </div>
      <div class="flex-1">
        <h4 class="font-orbitron text-base font-black uppercase" style="color: #f9f5fd;">Xbox 360</h4>
        <p class="font-label text-xs mt-0.5" style="color: #76747b;">680 games beschikbaar</p>
      </div>
      <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-all translate-x-[-10px] group-hover:translate-x-0" style="color: #107c10;">arrow_forward</span>
    </a>

  </div>

</div>
</section>
