---
---
<div class="product-skeleton min-w-[240px] md:min-w-[260px] snap-start flex-shrink-0 rounded-xl overflow-hidden animate-pulse" 
     style="background: #1a1a22; border: 1px solid rgba(72,71,77,0.2);">

  <!-- Image area skeleton -->
  <div class="w-full h-[260px]" style="background: #1e1e26;"></div>

  <!-- Info area skeleton -->
  <div class="px-4 pt-4 pb-5 space-y-3">
    <!-- Title skeleton -->
    <div class="h-4 w-3/4 rounded" style="background: #25252d;"></div>
    <!-- Platform skeleton -->
    <div class="h-2 w-1/2 rounded" style="background: #25252d;"></div>
    
    <div class="flex items-center justify-between pt-2">
      <!-- Price skeleton -->
      <div class="h-6 w-1/3 rounded" style="background: #25252d;"></div>
      <!-- Icon skeleton -->
      <div class="w-6 h-6 rounded-full" style="background: #25252d;"></div>
    </div>
  </div>
</div>
