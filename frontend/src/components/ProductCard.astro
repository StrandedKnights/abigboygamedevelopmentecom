---
const { product } = Astro.props;
---
<div class="reveal reveal-up group relative bg-surface border border-white/5 rounded-sm p-4 transition-all duration-300 hover:border-primary/30 hover:shadow-[0_0_30px_rgba(155,95,224,0.1)]">
    <div class="relative aspect-square overflow-hidden rounded-sm mb-4">
    
    {product.isLegacy && (
        <div class="absolute -right-12 top-6 bg-accent text-background font-teko font-bold text-xl uppercase tracking-widest px-12 py-1 rotate-45 z-20 shadow-md">
            LEGACY
        </div>
    )}

    <div class="aspect-square bg-background/50 relative overflow-hidden flex items-center justify-center p-6">
        <img src={product.imageUrl} alt={product.title} class="w-full h-full object-contain drop-shadow-[0_0_10px_rgba(232,179,255,0.2)] group-hover:scale-110 transition-transform duration-500" />
    </div>

    <div class="p-6 flex flex-col flex-1 relative z-10">
        <p class="font-inter text-xs text-secondary/70 uppercase tracking-widest mb-1">{product.platform} &bull; {product.condition}</p>
        <h3 class="font-teko text-3xl text-secondary leading-none uppercase tracking-wide mb-4 group-hover:text-primary transition-colors">{product.title}</h3>
        
        <div class="mt-auto flex items-end justify-between">
            <span class="font-teko text-4xl text-primary leading-none tracking-wider">€ {(product.priceInCents / 100).toFixed(2)}</span>
            
            <button class="w-12 h-12 bg-primary/10 border border-primary/20 backdrop-blur-md flex items-center justify-center rounded-lg hover:bg-primary/30 hover:text-accent transition-colors text-primary shadow-[0_0_10px_rgba(232,179,255,0.1)]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            </button>
        </div>
    </div>
</div>
