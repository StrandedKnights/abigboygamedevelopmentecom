---
interface Props {
  product?: {
    id: string;
    title: string;
    platform: string;
    priceInCents: number;
    imageUrl: string;
    platformColor: string;
  };
  index?: number;
}

const { product, index = 0 } = Astro.props;

// Default to empty if not provided (for JS injection template)
const p = product || {
    id: '',
    title: '',
    platform: '',
    priceInCents: 0,
    imageUrl: '',
    platformColor: '#d593ff'
};
---

<div class="product-card reveal reveal-up min-w-[240px] md:min-w-[260px] snap-start flex-shrink-0 rounded-xl overflow-hidden group cursor-pointer transition-all duration-300 hover:-translate-y-1" 
     style={`background: #1a1a22; border: 1px solid rgba(72,71,77,0.2); transition-delay: ${index * 100}ms;`}
     data-id={p.id}>

  <!-- Image area -->
  <div class="relative overflow-hidden" style="height: 260px; background: #111118;">
    <img
      src={p.imageUrl}
      alt={p.title}
      class="product-image w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
    <!-- PRE-OWNED badge -->
    <span class="absolute top-3 left-3 font-orbitron text-[9px] font-black uppercase tracking-widest px-2 py-1" style="background: #00FF88; color: #000;">Pre-owned</span>
    <!-- Add to cart overlay on hover -->
    <div class="absolute bottom-0 left-0 right-0 py-3 text-center font-orbitron text-[10px] font-bold uppercase tracking-widest translate-y-full group-hover:translate-y-0 transition-transform duration-300 shadow-[0_-10px_30px_rgba(155,95,224,0.3)]" style="background: #d593ff; color: #fff;">
      + Toevoegen
    </div>
  </div>

  <!-- Info area -->
  <div class="px-4 pt-4 pb-5 space-y-1.5">
    <h3 class="product-title font-orbitron font-bold text-sm leading-snug line-clamp-1 uppercase tracking-tight" style="color: #f9f5fd;">{p.title}</h3>
    <p class="product-platform font-orbitron text-[10px] uppercase tracking-wider" style={`color: ${p.platformColor};`}>{p.platform}</p>
    <div class="flex items-center justify-between pt-2">
      <span class="product-price font-orbitron text-lg font-bold" style="color: #f9f5fd;">€{(p.priceInCents / 100).toFixed(2).replace('.', ',')}</span>
      <button class="transition-colors p-1" style="color: #48474d;" onmouseover="this.style.color='#00FF88'" onmouseout="this.style.color='#48474d'">
        <span class="material-symbols-outlined text-base">star</span>
      </button>
    </div>
  </div>
</div>
