---
---
<nav class="fixed top-0 w-full h-[56px] md:h-[64px] z-50 bg-[#0e0e13]/80 backdrop-blur-md flex justify-between items-center px-4 md:px-8 shadow-[0_0_20px_rgba(155,95,224,0.1)] border-b border-[#2a1a3e]">
  <!-- Brand -->
  <div class="flex items-center gap-3">
    <img src="/images/logo.jpg" alt="A Big Boy's Game" class="w-8 h-8 object-cover rounded-sm mix-blend-lighten"/>
    <span class="font-orbitron text-base font-black tracking-tighter uppercase" style="color: #f9f5fd;">Abig<span style="color: #d593ff;">Boys</span>Game</span>
  </div>

  <!-- Nav links -->
  <div class="hidden md:flex items-center gap-8 font-headline tracking-wider uppercase text-sm">
    <a class="transition-all hover:text-white" style="color: #acaab1;" href="/">Home</a>
    <a class="transition-all hover:text-[#d593ff]" style="color: #acaab1;" href="/shop">Shop</a>
    <a class="transition-all hover:text-[#d593ff]" style="color: #acaab1;" href="/contact">Contact</a>
    <a class="transition-all hover:text-[#d593ff]" style="color: #acaab1;" href="/over-ons">Over Ons</a>
  </div>


  <!-- Icons -->
  <div class="flex items-center gap-4" style="color: #d593ff;">
    <button class="material-symbols-outlined p-2 scale-95 active:scale-90 duration-200 hover:opacity-80">search</button>
    <button class="material-symbols-outlined p-2 scale-95 active:scale-90 duration-200 hover:opacity-80">account_circle</button>
    <div class="relative group">
      <button id="cart-toggle-btn" class="material-symbols-outlined p-2 scale-95 active:scale-90 duration-200 hover:opacity-80">
        shopping_cart
      </button>
      
      <!-- Cart Badge (Dynamic via client side script) -->
      <span id="cart-badge" class="absolute top-1 right-1 w-4 h-4 rounded-full flex items-center justify-center font-orbitron font-black text-[9px] text-black transform scale-0 transition-transform duration-300 pointer-events-none" style="background: #00FF88; box-shadow: 0 0 10px rgba(0,255,136,0.5);">
        0
      </span>
    </div>
  </div>
</nav>

<script>
  import { isCartOpen } from '../store/uiStore';
  import { cartItems } from '../store/cartStore';

  // Toggle Cart
  const cartBtn = document.getElementById('cart-toggle-btn');
  if (cartBtn) {
    cartBtn.addEventListener('click', () => {
      isCartOpen.set(true);
    });
  }

  // Auto-update Badge Count
  const badge = document.getElementById('cart-badge');
  if (badge) {
    cartItems.subscribe((items) => {
      badge.textContent = items.length.toString();
      if (items.length > 0) {
        badge.classList.remove('scale-0');
        badge.classList.add('scale-100');
      } else {
        badge.classList.remove('scale-100');
        badge.classList.add('scale-0');
      }
    });
  }
</script>
