<div class="flex gap-6">
<a class="text-[11px] tracking-[0.1em] hover:text-white" style="color: #acaab1;" href="#">Algemene Voorwaarden</a>
<a class="text-[11px] tracking-[0.1em] hover:text-white" style="color: #acaab1;" href="#">Privacybeleid</a>
</div>
