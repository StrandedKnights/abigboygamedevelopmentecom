---
---
<section class="relative min-h-[130vh] pt-[64px] pb-48 flex items-center overflow-hidden" style="background: radial-gradient(circle at center, #6A0DAD 0%, #0A0A0F 70%);">
<!-- Logo as full-section background -->
<div class="absolute inset-0 z-0">
<img alt="" class="w-full h-full object-cover mix-blend-lighten opacity-25" src="/images/logo.jpg"/>
</div>
<div class="absolute inset-0 scanline-overlay z-10 opacity-30"></div>
    <div class="relative z-10 container mx-auto px-6 pt-32 pb-20 md:pt-48 md:pb-32">
        <div class="max-w-4xl">
            <h1 class="reveal reveal-up font-barlow font-black text-6xl md:text-9xl leading-[0.85] tracking-tighter uppercase text-white mb-6" 
                style="-webkit-text-stroke: 1px rgba(0,0,0,0.5); text-shadow: 2px 2px 0px #000, 0 0 20px rgba(155,95,224,0.3);">
                ABIGBOYS <br/>
                <span id="cycle-text" class="text-primary inline-block min-h-[1em]" style="color: #d593ff; border-right: 2px solid #d593ff; padding-right: 5px;">GAME</span>
            </h1>

            <script>
                const words = ["GAME", "COLLECTIBLES", "PARADIJS"];
                let wordIndex = 0;
                let charIndex = 0;
                let isDeleting = false;
                const cycleText = document.getElementById('cycle-text');

                function type() {
                    const currentWord = words[wordIndex];
                    if (isDeleting) {
                        cycleText.textContent = currentWord.substring(0, charIndex - 1);
                        charIndex--;
                    } else {
                        cycleText.textContent = currentWord.substring(0, charIndex + 1);
                        charIndex++;
                    }

                    let typeSpeed = isDeleting ? 50 : 150;

                    if (!isDeleting && charIndex === currentWord.length) {
                        typeSpeed = 2500; // Pause at the end
                        isDeleting = true;
                        cycleText.style.borderRightColor = 'transparent';
                        setTimeout(() => { cycleText.style.borderRightColor = '#d593ff'; }, 500);
                        setTimeout(() => { cycleText.style.borderRightColor = 'transparent'; }, 1000);
                        setTimeout(() => { cycleText.style.borderRightColor = '#d593ff'; }, 1500);
                    } else if (isDeleting && charIndex === 0) {
                        isDeleting = false;
                        wordIndex = (wordIndex + 1) % words.length;
                        typeSpeed = 500;
                    }

                    setTimeout(type, typeSpeed);
                }

                if (cycleText) {
                    // Start the typing effect
                    setTimeout(type, 1000);
                }
            </script>
            <p class="reveal reveal-up font-orbitron text-sm md:text-base tracking-[0.3em] uppercase text-on-surface-variant font-medium mb-10 [transition-delay:200ms]" 
               style="color: #acaab1 !important; text-shadow: 1px 1px 2px rgba(0,0,0,0.8); -webkit-text-stroke: 0.5px #000;">
                Premium Retro & Next-Gen Gaming Collectibles
            </p>
<div class="flex flex-wrap gap-4 pt-2">
<button class="font-orbitron font-bold py-4 px-8 rounded-sm neon-glow transform hover:scale-105 transition-all uppercase tracking-widest text-sm" style="background: linear-gradient(to right, #d593ff, #8b4fd0); color: #f9f5fd;">
                        Bekijk Aanbod
                    </button>
                    <button class="font-orbitron font-bold py-4 px-8 rounded-sm hover:opacity-80 transition-all uppercase tracking-widest text-sm backdrop-blur-sm" style="border: 1px solid rgba(72,71,77,0.4); background: rgba(31,31,38,0.5); color: #f9f5fd;">
                        Over Ons
                    </button>
</div>
</div>
</div>
<!-- Scrolling Ticker -->
<div class="absolute top-[64px] w-full backdrop-blur-sm py-3 overflow-hidden z-30" style="background: rgba(0,0,0,0.8); border-top: 1px solid rgba(155,95,224,0.2); border-bottom: 1px solid rgba(155,95,224,0.2);">
<div class="ticker-scroll flex items-center gap-12 font-orbitron text-sm font-bold tracking-[0.3em]" style="color: #d593ff;">
<span>NES · N64 · PS1 · PS2 · XBOX · SEGA · GAMEBOY · GAME CUBE · WII · 3DS · NINTENDO SWITCH · XBOX 360 · WII U · NINTENDO DS</span>
<span>NES · N64 · PS1 · PS2 · XBOX · SEGA · GAMEBOY · GAME CUBE · WII · 3DS · NINTENDO SWITCH · XBOX 360 · WII U · NINTENDO DS</span>
</div>
</div>
</section>
