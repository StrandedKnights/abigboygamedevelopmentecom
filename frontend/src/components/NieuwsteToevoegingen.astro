---
import ProductCard from './ProductCard.astro';
import { ProductsAPI } from '../services/apiClient';

let products: Array<any> = [];

try {
  products = await ProductsAPI.getLatestAdditions();
} catch (e) {
  console.error("SSR failed to fetch Nieuwste Toevoegingen", e);
}

const getPlatformColor = (platform: string) => {
  if (platform.includes('PlayStation')) return '#3344ff';
  if (platform.includes('Nintendo')) return '#e60012';
  if (platform.includes('Xbox')) return '#107c10';
  return '#d593ff'; // Default purple
};
---

<section class="py-16 px-6 overflow-hidden" style="background-color: #0d0d12;">
    <div class="max-w-screen-2xl mx-auto">
        <div class="reveal reveal-left flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
            <div>
                <p class="font-orbitron text-xs tracking-[0.4em] uppercase mb-4" style="color: #d593ff;">Fresh drops</p>
                <h2 class="font-barlow font-black text-5xl md:text-7xl tracking-tight uppercase" style="color: #f9f5fd;">Nieuwste <br class="md:hidden"/> <span style="color: #d593ff;">Toevoegingen</span></h2>
            </div>
      <div class="flex items-center gap-4 w-full md:w-auto justify-between md:justify-end">
        <div class="flex items-center gap-3">
          <button id="scroll-prev" class="w-10 h-10 flex items-center justify-center rounded-sm transition-all" style="background:#1a1a22;border:1px solid rgba(72,71,77,0.4);color:#acaab1;">
            <span class="material-symbols-outlined text-base">chevron_left</span>
          </button>
          <button id="scroll-next" class="w-10 h-10 flex items-center justify-center rounded-sm transition-all" style="background:#1a1a22;border:1px solid rgba(72,71,77,0.4);color:#acaab1;">
            <span class="material-symbols-outlined text-base">chevron_right</span>
          </button>
        </div>
        <a href="/shop?sortBy=newest" class="group ml-4 inline-flex items-center gap-1 font-orbitron text-xs font-bold uppercase tracking-[0.2em] transition-all whitespace-nowrap" style="color: #d593ff;">
          Toon alles
          <span class="material-symbols-outlined text-sm transition-transform duration-200 group-hover:translate-x-1">arrow_forward</span>
        </a>
      </div>
    </div>

    <!-- Product cards container -->
    <div id="card-track" class="flex gap-5 overflow-x-auto pb-4 snap-x snap-mandatory" style="scrollbar-width:none;-ms-overflow-style:none;">
      {products.length > 0 ? products.map((product, index) => (
        <ProductCard product={{ ...product, platformColor: getPlatformColor(product.platform) }} index={index} />
      )) : (
        <p class="text-[#acaab1] py-10 w-full text-center font-orbitron text-sm uppercase tracking-widest">Momenteel geen producten gevonden.</p>
      )}
    </div>

  </div>
</section>

<script>
  // Simple Horizontal Scroll Handling
  document.getElementById('scroll-prev')?.addEventListener('click', () => {
    document.getElementById('card-track')?.scrollBy({ left: -285, behavior: 'smooth' });
  });
  
  document.getElementById('scroll-next')?.addEventListener('click', () => {
    document.getElementById('card-track')?.scrollBy({ left: 285, behavior: 'smooth' });
  });
</script>

<style>
  /* Ensure the hover styles work for dynamically injected elements */
  #card-track::-webkit-scrollbar {
    display: none;
  }
</style>
