    { id: '6', title: 'GoldenEye 007', platform: 'Nintendo 64', priceInCents: 5500, imageUrl: 'https://lh3.googleusercontent.com/aida-public/AB6AXuA9f9e7cxJx_3k0IWes77auUoq2N2hEUbXfq8LKM8kWdwKaC9j9hg_OXm0vegfuUQRiNVw2jAczPnoO5jxG1JtIgS1dLAF162Wi4ZmrC3mOteiY_sUKUKBjxrurIDdweXgDZJSZPFWVvIqJaE8vw_TYrJoRxRSJtNw_OwIeqsy-7zZMlAf5Rp1ymJvZR4PS9COaMccp7l0u2XzHWnS-lNsJVWNSo_cjqmQN7E2Ev-dNOOFC7_IiCIuvFxMqrv3nuvehLaUEf-jfFlk', platformColor: '#ff4b4b' },
];

try {
    const res = await fetch('http://localhost:3000/api/products');
    if (res.ok) {
        const data = await res.json();
        if (data.length > 0) {
            products = data.map(p => ({ ...p, platformColor: '#9b5fe0' }));
        }
    }
} catch (e) {}

if (products.length === 0) products = fallbackProducts;
---

<section class="py-16 overflow-hidden" style="background-color: #0d0d12;">
    <div class="max-w-7xl mx-auto">
        <div class="reveal reveal-left flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
            <div>
                <p class="font-orbitron text-xs tracking-[0.4em] uppercase mb-4" style="color: #9b5fe0;">Fresh drops</p>
                <h2 class="font-barlow font-black text-5xl md:text-7xl tracking-tight uppercase" style="color: #f9f5fd;">Nieuwste <br class="md:hidden"/> <span style="color: #9b5fe0;">Toevoegingen</span></h2>
            </div>
      <div class="flex items-center gap-4 w-full md:w-auto justify-between md:justify-end">
        <div class="flex items-center gap-3">
          <button id="scroll-prev" onclick="document.getElementById('card-track').scrollBy({left:-285,behavior:'smooth'})" class="w-10 h-10 flex items-center justify-center rounded-sm transition-all" style="background:#1a1a22;border:1px solid rgba(72,71,77,0.4);color:#acaab1;" onmouseover="this.style.borderColor='rgba(155,95,224,0.5)';this.style.color='#9b5fe0'" onmouseout="this.style.borderColor='rgba(72,71,77,0.4)';this.style.color='#acaab1'">
            <span class="material-symbols-outlined text-base">chevron_left</span>
          </button>
          <button id="scroll-next" onclick="document.getElementById('card-track').scrollBy({left:285,behavior:'smooth'})" class="w-10 h-10 flex items-center justify-center rounded-sm transition-all" style="background:#1a1a22;border:1px solid rgba(72,71,77,0.4);color:#acaab1;" onmouseover="this.style.borderColor='rgba(155,95,224,0.5)';this.style.color='#9b5fe0'" onmouseout="this.style.borderColor='rgba(72,71,77,0.4)';this.style.color='#acaab1'">
            <span class="material-symbols-outlined text-base">chevron_right</span>
          </button>
        </div>
        <a href="#" class="group ml-4 inline-flex items-center gap-1 font-orbitron text-xs font-bold uppercase tracking-[0.2em] transition-all whitespace-nowrap" style="color: #9b5fe0;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
          Toon alles
          <span class="material-symbols-outlined text-sm transition-transform duration-200 group-hover:translate-x-1">arrow_forward</span>
        </a>
      </div>
    </div>

    <!-- Product cards row -->
    <div id="card-track" class="flex gap-5 overflow-x-auto pb-4 snap-x snap-mandatory" style="scrollbar-width:none;-ms-overflow-style:none;">
      {products.map((product, index) => (
        <div class="reveal reveal-up min-w-[240px] md:min-w-[260px] snap-start flex-shrink-0 rounded-xl overflow-hidden group cursor-pointer transition-all duration-300 hover:-translate-y-1" 
             style={`background: #1a1a22; border: 1px solid rgba(72,71,77,0.2); transition-delay: ${index * 100}ms;`}>

          <!-- Image area -->
          <div class="relative overflow-hidden" style="height: 260px; background: #111118;">
            <img
              src={product.imageUrl}
              alt={product.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <!-- PRE-OWNED badge -->
            <span class="absolute top-3 left-3 font-orbitron text-[9px] font-black uppercase tracking-widest px-2 py-1" style="background: #f5c518; color: #000;">Pre-owned</span>
            <!-- Add to cart overlay on hover -->
            <div class="absolute bottom-0 left-0 right-0 py-3 text-center font-orbitron text-[10px] font-bold uppercase tracking-widest translate-y-full group-hover:translate-y-0 transition-transform duration-300" style="background: #9b5fe0; color: #fff;">
              + Toevoegen
            </div>
          </div>

          <!-- Info area -->
          <div class="px-4 pt-4 pb-5 space-y-1.5">
            <h3 class="font-bold text-sm leading-snug line-clamp-1" style="color: #f9f5fd;">{product.title}</h3>
            <p class="font-orbitron text-[10px] uppercase tracking-wider" style={`color: ${product.platformColor};`}>{product.platform}</p>
            <div class="flex items-center justify-between pt-2">
              <span class="font-orbitron text-lg font-bold" style="color: #f9f5fd;">€{(product.priceInCents / 100).toFixed(2).replace('.', ',')}</span>
              <button class="transition-colors p-1" style="color: #48474d;" onmouseover="this.style.color='#f5c518'" onmouseout="this.style.color='#48474d'">
                <span class="material-symbols-outlined text-base">star</span>
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
