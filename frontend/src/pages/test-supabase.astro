---
import BaseLayout from '../layouts/BaseLayout.astro';
import { supabase } from '../db/supabase';

// Supabase Quickstart Fetch
const { data, error } = await supabase.from("todos").select('*');
---

<BaseLayout title="Supabase Quickstart Test">
  <main class="min-h-screen pt-32 pb-20 container mx-auto px-4">
    <div class="glass-panel p-8 rounded-2xl border border-white/10 relative overflow-hidden">
      <!-- Cyberpunk decorative glow -->
      <div class="absolute -top-32 -left-32 w-64 h-64 bg-brand-purple/20 blur-[100px] rounded-full"></div>
      
      <h1 class="text-4xl font-orbitron font-black text-white mb-6 uppercase tracking-wider">
        <span class="text-brand-purple">SUPABASE</span> TEST
      </h1>
      
      {error ? (
        <div class="p-4 bg-red-500/10 border border-red-500/50 rounded-lg">
          <p class="text-red-400 font-inter">❌ Database Error: {error.message}</p>
        </div>
      ) : (
        <div class="space-y-4">
          <p class="text-gray-300 font-inter mb-4">Successfully connected to Supabase URL: <code>{import.meta.env.PUBLIC_SUPABASE_URL}</code></p>
          
          {data && data.length > 0 ? (
            <ul class="space-y-2">
              {data.map((entry) => (
                <li class="p-3 bg-white/5 border border-white/10 rounded-lg text-white font-inter">
                  ✅ {entry.name || JSON.stringify(entry)}
                </li>
              ))}
            </ul>
          ) : (
            <div class="p-4 bg-white/5 border border-white/10 rounded-lg text-gray-400 italic">
              Table 'todos' connected, but no data found. Please create some rows in the Supabase Dashboard!
            </div>
          )}
        </div>
      )}
    </div>
  </main>
</BaseLayout>
