---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNavBar from '../components/TopNavBar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Veelgestelde Vragen | ABigBoysGame" description="Vind antwoorden op al je vragen over onze retro games, consoles en service.">
    <TopNavBar />
    <div class="relative min-h-screen pt-32 pb-24" style="background-color: #0e0e13;">
        <!-- Background Glow -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none opacity-20" 
             style="background: radial-gradient(circle at 50% 0%, #9b5fe0 0%, transparent 70%);">
        </div>

        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <div class="text-center mb-16">
                <span class="font-orbitron text-[#9b5fe0] text-sm tracking-[0.3em] uppercase mb-4 block">Hulp nodig?</span>
                <h1 class="font-barlow font-black text-6xl md:text-7xl text-white uppercase leading-none italic tracking-tighter">
                   FAQ
                </h1>
                <p class="text-[#acaab1] mt-6 text-lg max-w-xl mx-auto">
                    Alles wat je moet weten over je volgende retro-aanwinst. Directe antwoorden, geen gedoe.
                </p>
            </div>

            <div class="space-y-4">
                <!-- Category: Producten -->
                <div class="mb-12">
                    <h2 class="font-orbitron text-white text-lg mb-6 flex items-center gap-3">
                        <span class="w-8 h-[1px] bg-[#9b5fe0]"></span>
                        Producten & Kwaliteit
                    </h2>
                    
                    <div class="space-y-4">
                        <details class="group border border-white/10 rounded-2xl bg-white/5 backdrop-blur-md overflow-hidden transition-all hover:border-[#9b5fe0]/30">
                            <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
                                <span class="font-barlow font-bold text-xl text-white uppercase tracking-tight">Zijn alle consoles en games origineel?</span>
                                <span class="transition-transform duration-300 group-open:rotate-180">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#9b5fe0]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="Wait, the SVG needs to be defined but I can just use a simple plus/minus or chevron." />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </span>
                            </summary>
                            <div class="px-6 pb-6 text-[#acaab1] leading-relaxed">
                                Ja, bij ABigBoysGame verkopen we uitsluitend originele hardware en software. Wij voeren een strikt beleid tegen reproducties en bootlegs. Elke game wordt gecontroleerd op echtheid van de printplaat (PCB).
                            </div>
                        </details>

                        <details class="group border border-white/10 rounded-2xl bg-white/5 backdrop-blur-md overflow-hidden transition-all hover:border-[#9b5fe0]/30">
                            <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
                                <span class="font-barlow font-bold text-xl text-white uppercase tracking-tight">Worden de consoles getest voor verkoop?</span>
                                <span class="transition-transform duration-300 group-open:rotate-180">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#9b5fe0]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </span>
                            </summary>
                            <div class="px-6 pb-6 text-[#acaab1] leading-relaxed">
                                Absoluut. Elke console ondergaat een uitgebreide stress-test. We controleren de disc drive, poorten, voeding en interne componenten. Waar nodig worden onderdelen gereinigd of vervangen.
                            </div>
                        </details>
                    </div>
                </div>

                <!-- Category: Bestellingen -->
                <div class="mb-12">
                    <h2 class="font-orbitron text-white text-lg mb-6 flex items-center gap-3">
                        <span class="w-8 h-[1px] bg-[#9b5fe0]"></span>
                        Verzending & Service
                    </h2>
                    
                    <div class="space-y-4">
                        <details class="group border border-white/10 rounded-2xl bg-white/5 backdrop-blur-md overflow-hidden transition-all hover:border-[#9b5fe0]/30">
                            <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
                                <span class="font-barlow font-bold text-xl text-white uppercase tracking-tight">Hoe snel wordt mijn pakket verzonden?</span>
                                <span class="transition-transform duration-300 group-open:rotate-180">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#9b5fe0]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </span>
                            </summary>
                            <div class="px-6 pb-6 text-[#acaab1] leading-relaxed">
                                Voor 15:00 uur besteld is dezelfde dag verzonden. Je ontvangt een Track & Trace code zodra je pakket onderweg is.
                            </div>
                        </details>

                        <details class="group border border-white/10 rounded-2xl bg-white/5 backdrop-blur-md overflow-hidden transition-all hover:border-[#9b5fe0]/30">
                            <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
                                <span class="font-barlow font-bold text-xl text-white uppercase tracking-tight">Wat is jullie retourbeleid?</span>
                                <span class="transition-transform duration-300 group-open:rotate-180">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#9b5fe0]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </span>
                            </summary>
                            <div class="px-6 pb-6 text-[#acaab1] leading-relaxed">
                                Vanwege de aard van verzamelitems en gebruikte electronica zijn <strong class="text-white">alle verkopen definitief</strong>. In het zeldzame geval van een defect bij aankomst binnen de garantieperiode, lossen we dit uiteraard voor je op.
                            </div>
                        </details>
                    </div>
                </div>
            </div>

            <!-- Contact CTA -->
            <div class="mt-20 p-12 rounded-3xl border border-[#9b5fe0]/20 bg-[#9b5fe0]/5 text-center relative overflow-hidden group">
                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-[#9b5fe0]/5 to-transparent transition-transform duration-1000 translate-x-[-100%] group-hover:translate-x-[100%]"></div>
                <h3 class="font-barlow font-black text-3xl text-white uppercase mb-4">Nog steeds vragen?</h3>
                <p class="text-[#acaab1] mb-8">Ons team van retro-experts staat klaar om je te helpen.</p>
                <a href="/contact" class="inline-block font-orbitron text-xs tracking-widest text-[#9b5fe0] border border-[#9b5fe0] px-8 py-4 rounded-full hover:bg-[#9b5fe0] hover:text-white transition-all">
                    NEEM CONTACT OP
                </a>
            </div>
        </div>
    </div>
    <Footer />
</BaseLayout>


<style>
    /* Custom removal of details marker in Safari */
    details > summary::-webkit-details-marker {
        display: none;
    }
</style>

