---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Veelgestelde Vragen | ABigBoysGame" description="Veelgestelde vragen over ABigBoysGame.">
    <div class="relative min-h-[60vh] pt-32 pb-24" style="background-color: #07070D;">
        <div class="max-w-3xl mx-auto px-6">
            <h1 class="font-barlow font-black text-5xl md:text-6xl text-white uppercase mb-8" style="color: #f9f5fd;">FAQ</h1>
            <div class="prose prose-invert prose-p:text-[#acaab1] prose-headings:text-[#f9f5fd] prose-a:text-[#9b5fe0]">
                <p>Vind de antwoorden op de meest gestelde vragen over onze retro games en consoles.</p>
                <h3>Verzending & Levering</h3>
                <p>Hoe lang duurt het voordat mijn bestelling wordt verzonden?</p>
                <h3>Garantie & Retourneren</h3>
                <p>Alle verkopen zijn definitief. Bekijk onze garantiepagina voor defecten.</p>
            </div>
        </div>
    </div>
</BaseLayout>
