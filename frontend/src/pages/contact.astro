---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNavBar from '../components/TopNavBar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact | ABigBoysGame" description="Neem contact op met ABigBoysGame voor al je retro gaming vragen.">
    <TopNavBar />
    <div class="relative min-h-screen pt-32 pb-24" style="background-color: #07070D;">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

                <!-- Text Content -->
                <div class="space-y-8">
                    <div>
                        <h1 class="font-barlow font-black text-5xl md:text-7xl text-white uppercase leading-tight mb-4" style="color: #f9f5fd;">
                            Contact <br/> <span style="color: #9b5fe0;">Opnemen</span>
                        </h1>
                        <p class="text-xl text-[#acaab1] font-body leading-relaxed max-w-md">
                            Heb je een vraag over een bestelling, een product, of iets anders? Wij helpen je graag verder!
                        </p>
                    </div>

                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 flex items-center justify-center rounded-xl" style="background: rgba(155, 95, 224, 0.1); border: 1px solid rgba(155, 95, 224, 0.2);">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="#9b5fe0">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-white font-headline font-bold text-lg mb-1">E-mail ons</h3>
                                <p class="text-[#acaab1] font-body">info@abigboysgame.nl</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 flex items-center justify-center rounded-xl" style="background: rgba(155, 95, 224, 0.1); border: 1px solid rgba(155, 95, 224, 0.2);">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="#9b5fe0">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-white font-headline font-bold text-lg mb-1">Reactietijd</h3>
                                <p class="text-[#acaab1] font-body">We streven ernaar om binnen 24 uur te reageren.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contact Form -->
                <div class="relative p-8 md:p-10 rounded-3xl" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px);">
                    <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
                        <input type="hidden" name="access_key" value="f08f8712-1ef7-4a07-a362-10ceb89373a5">
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label for="name" class="text-sm font-headline text-gray-400 uppercase tracking-wider">Naam</label>
                                <input type="text" name="name" id="name" required class="w-full px-4 py-3 rounded-xl outline-none transition-all duration-300 focus:ring-2 focus:ring-[#9b5fe0]/50" style="background: #000; border: 1px solid rgba(255,255,255,0.1); color: #fff;">
                            </div>
                            <div class="space-y-2">
                                <label for="email" class="text-sm font-headline text-gray-400 uppercase tracking-wider">E-mail</label>
                                <input type="email" name="email" id="email" required class="w-full px-4 py-3 rounded-xl outline-none transition-all duration-300 focus:ring-2 focus:ring-[#9b5fe0]/50" style="background: #000; border: 1px solid rgba(255,255,255,0.1); color: #fff;">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label for="ordernummer" class="text-sm font-headline text-gray-400 uppercase tracking-wider">Ordernummer (Optioneel)</label>
                            <input type="text" name="ordernummer" id="ordernummer" class="w-full px-4 py-3 rounded-xl outline-none transition-all duration-300 focus:ring-2 focus:ring-[#9b5fe0]/50" style="background: #000; border: 1px solid rgba(255,255,255,0.1); color: #fff;" placeholder="#ABB-0000">
                        </div>

                        <div class="space-y-2">
                            <label for="message" class="text-sm font-headline text-gray-400 uppercase tracking-wider">Bericht</label>
                            <textarea name="message" id="message" rows="5" required class="w-full px-4 py-3 rounded-xl outline-none transition-all duration-300 focus:ring-2 focus:ring-[#9b5fe0]/50 resize-none" style="background: #000; border: 1px solid rgba(255,255,255,0.1); color: #fff;"></textarea>
                        </div>

                        <button type="submit" class="w-full py-4 rounded-xl font-headline font-black text-white uppercase tracking-widest transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]" style="background: linear-gradient(135deg, #9b5fe0 0%, #7a3ec0 100%);">
                            Verstuur Bericht
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <Footer />
</BaseLayout>

