---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | ABigBoysGame" description="Neem contact op met ABigBoysGame voor al je retro gaming vragen.">
    <div class="relative min-h-[60vh] pt-32 pb-24" style="background-color: #07070D;">
        <div class="max-w-3xl mx-auto px-6">
            <h1 class="font-barlow font-black text-5xl md:text-6xl text-white uppercase mb-8" style="color: #f9f5fd;">Contact</h1>
            <div class="prose prose-invert prose-p:text-[#acaab1] prose-headings:text-[#f9f5fd] prose-a:text-[#9b5fe0]">
                <p>Heb je een vraag over een bestelling, een product, of iets anders? Wij helpen je graag verder!</p>
                <h3>Klantenservice</h3>
                <p>Je kunt ons bereiken via e-mail of via onze sociale media kanalen. We streven ernaar om binnen 24 uur te reageren.</p>
                <ul>
                    <li>Email: info@abigboysgame.nl</li>
                </ul>
            </div>
        </div>
    </div>
</BaseLayout>
