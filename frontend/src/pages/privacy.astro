---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNavBar from '../components/TopNavBar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Privacybeleid | ABigBoysGame" description="Privacybeleid van ABigBoysGame ter bescherming van jouw gegevens.">
    <TopNavBar />
    <div class="relative min-h-screen pt-32 pb-24" style="background-color: #0e0e13;">
        <!-- Background Glow -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none opacity-20" 
             style="background: radial-gradient(circle at 50% 10%, #d593ff 0%, transparent 70%);">
        </div>

        <div class="max-w-7xl mx-auto px-6 relative z-10">

            <!-- Header -->
            <div class="text-center mb-16">
                <h1 class="font-barlow font-black text-6xl md:text-7xl text-white uppercase leading-none italic tracking-tighter">
                   Privacybeleid
                </h1>
                <p class="text-[#acaab1] mt-4 font-orbitron text-[10px] tracking-[0.4em] uppercase">Data Protection Protocol</p>
            </div>

            <!-- Content Cards -->
            <div class="space-y-6">
                <div class="p-8 md:p-12 rounded-[2rem] border border-white/10 bg-white/5 backdrop-blur-xl">
                    <h2 class="font-barlow font-bold text-3xl text-white uppercase italic mb-6">Onze Inzet</h2>
                    <p class="text-[#acaab1] leading-relaxed text-lg mb-4">
                        Bij ABigBoysGame respecteren we de privacy van alle gebruikers van onze site. Wij dragen er zorg voor dat de persoonlijke informatie die je ons verschaft vertrouwelijk wordt behandeld en beveiligd volgens de laatste standaarden.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="p-8 rounded-[2rem] border border-white/10 bg-white/5 backdrop-blur-xl">
                        <h3 class="font-barlow font-bold text-2xl text-white uppercase italic mb-4 text-[#d593ff]">Data Verzameling</h3>
                        <p class="text-[#acaab1] leading-relaxed">
                            Wanneer je een bestelling plaatst, hebben we je naam, e-mailadres, afleveradres en betaalgegevens nodig om de order te verwerken en je op de hoogte te houden.
                        </p>
                    </div>
                    <div class="p-8 rounded-[2rem] border border-white/10 bg-white/5 backdrop-blur-xl">
                        <h3 class="font-barlow font-bold text-2xl text-white uppercase italic mb-4 text-[#d593ff]">Veiligheid</h3>
                        <p class="text-[#acaab1] leading-relaxed">
                            Jouw gegevens zijn veilig bij ons. Wij maken gebruik van SSL-encryptie voor alle transacties en verkopen jouw data NOOIT aan derden.
                        </p>
                    </div>
                </div>

                <div class="p-8 md:p-12 rounded-[2rem] border border-white/10 bg-gradient-to-br from-white/5 to-transparent backdrop-blur-md">
                    <h2 class="font-barlow font-bold text-3xl text-white uppercase italic mb-6">Cookies & Tracking</h2>
                    <p class="text-[#acaab1] leading-relaxed">
                        Wij gebruiken functionele cookies om je winkelervaring te verbeteren. Analytische cookies helpen ons de website te optimaliseren voor een betere retro-vibe. Je kunt cookies te allen tijde uitschakelen via je browserinstellingen.
                    </p>
                </div>
            </div>

            <!-- Footer Note -->
            <div class="mt-16 text-center text-[#acaab1] text-sm italic">
                Laatst bijgewerkt: Maart 2024
            </div>
        </div>
    </div>
    <Footer />
</BaseLayout>


