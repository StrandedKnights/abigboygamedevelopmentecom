---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNavBar from '../components/TopNavBar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Privacybeleid | A Big Boy's Game">
    <TopNavBar />
    
    <main class="max-w-4xl mx-auto px-6 py-24 lg:py-32 mt-16">
        <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-wider mb-12 text-on-background">
            Privacy<span class="text-primary">beleid</span>
        </h1>
        
        <div class="prose prose-invert prose-purple max-w-none space-y-8 font-body text-on-surface-variant leading-relaxed">
            <section class="bg-white/5 p-8 rounded-2xl border border-white/10 backdrop-blur-sm">
                <h2 class="text-2xl font-headline uppercase tracking-widest text-[#d593ff] mb-4">Inleiding</h2>
                <p>
                    A Big Boy's Game respecteert de privacy van de bezoekers van haar website en draagt er zorg voor dat de persoonlijke informatie die u ons verschaft vertrouwelijk wordt behandeld. Wij verwerken persoonsgegevens in overeenstemming met de Algemene Verordening Gegevensbescherming (AVG).
                </p>
            </section>

            <section class="bg-white/5 p-8 rounded-2xl border border-white/10 backdrop-blur-sm">
                <h2 class="text-2xl font-headline uppercase tracking-widest text-[#d593ff] mb-4">Welke gegevens verzamelen wij?</h2>
                <p>Wanneer u een bestelling plaatst, hebben wij de volgende gegevens nodig om uw bestelling uit te voeren en u van het verloop daarvan op de hoogte te houden:</p>
                <ul class="list-disc ml-6 space-y-2">
                    <li>Naam en adresgegevens</li>
                    <li>E-mailadres</li>
                    <li>Betaalgegevens</li>
                    <li>IP-adres (voor fraudepreventie)</li>
                </ul>
            </section>

            <section class="bg-white/5 p-8 rounded-2xl border border-white/10 backdrop-blur-sm">
                <h2 class="text-2xl font-headline uppercase tracking-widest text-[#d593ff] mb-4">Doeleinden van de verwerking</h2>
                <p>Wij gebruiken uw gegevens uitsluitend voor de volgende doeleinden:</p>
                <ul class="list-disc ml-6 space-y-2">
                    <li>Het verwerken en verzenden van uw bestelling.</li>
                    <li>Klantenservice en correspondentie over uw aankoop.</li>
                    <li>Het voldoen aan wettelijke verplichtingen (zoals belastingaangifte).</li>
                </ul>
            </section>

            <section class="bg-white/5 p-8 rounded-2xl border border-white/10 backdrop-blur-sm">
                <h2 class="text-2xl font-headline uppercase tracking-widest text-[#d593ff] mb-4">Delen met derden</h2>
                <p>
                    Wij delen uw gegevens alleen met derden die strikt noodzakelijk zijn voor onze dienstverlening. Denk hierbij aan betaalprovider Mollie, onze hostingpartner en bezorgdiensten (PostNL/DHL). Wij verkopen uw gegevens nooit aan derden.
                </p>
            </section>

            <section class="bg-white/5 p-8 rounded-2xl border border-white/10 backdrop-blur-sm">
                <h2 class="text-2xl font-headline uppercase tracking-widest text-[#d593ff] mb-4">Uw rechten</h2>
                <p>
                    U heeft het recht om uw persoonsgegevens in te zien, te corrigeren of te laten verwijderen. Neem hiervoor contact met ons op via <a href="mailto:info@abigboysgame.com" class="text-[#d593ff] hover:underline">info@abigboysgame.com</a>.
                </p>
            </section>
        </div>
    </main>

    <Footer />
</BaseLayout>
