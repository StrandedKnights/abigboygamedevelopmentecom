---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNavBar from '../components/TopNavBar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Algemene Voorwaarden | ABigBoysGame" description="De algemene voorwaarden van ABigBoysGame.">
    <TopNavBar />
    <div class="relative min-h-screen pt-32 pb-24" style="background-color: #0e0e13;">
        <!-- Background Glow -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none opacity-20" 
             style="background: radial-gradient(circle at 50% 10%, #d593ff 0%, transparent 70%);">
        </div>

        <div class="max-w-7xl mx-auto px-6 relative z-10">

            <!-- Header -->
            <div class="text-center mb-16">
                <h1 class="font-barlow font-black text-6xl md:text-7xl text-white uppercase leading-none italic tracking-tighter">
                   Voorwaarden
                </h1>
                <p class="text-[#acaab1] mt-4 font-orbitron text-[10px] tracking-[0.4em] uppercase">Terms of Engagement</p>
            </div>

            <!-- Content Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
                <!-- Section 1 -->
                <div class="p-10 rounded-[2.5rem] border border-white/10 bg-white/5 backdrop-blur-xl relative group">
                    <div class="w-12 h-12 bg-[#d593ff]/20 rounded-xl flex items-center justify-center mb-6 text-[#d593ff] border border-[#d593ff]/30 font-orbitron text-lg font-bold">01</div>
                    <h2 class="font-barlow font-black text-3xl text-white uppercase mb-4 italic">Toepasbaarheid</h2>
                    <p class="text-[#acaab1] leading-relaxed">
                        Deze algemene voorwaarden zijn van toepassing op alle aanbiedingen, bestellingen en overeenkomsten van ABigBoysGame. Door een bestelling te plaatsen, ga je akkoord met deze voorwaarden.
                    </p>
                </div>

                <!-- Section 2 -->
                <div class="p-10 rounded-[2.5rem] border border-white/10 bg-white/5 backdrop-blur-xl relative group">
                    <div class="w-12 h-12 bg-[#d593ff]/20 rounded-xl flex items-center justify-center mb-6 text-[#d593ff] border border-[#d593ff]/30 font-orbitron text-lg font-bold">02</div>
                    <h2 class="font-barlow font-black text-3xl text-white uppercase mb-4 italic">Aanbod & Prijzen</h2>
                    <div class="text-[#acaab1] leading-relaxed space-y-4">
                        <p>
                            Alle prijzen zijn in Euro's. Bij sommige producten (zoals gebruikte retro games) maken wij gebruik van de <strong>margeregeling</strong>, waarbij 0% BTW van toepassing is. Voor nieuwe producten zijn prijzen inclusief BTW.
                        </p>
                        <p>
                            Verzendkosten zijn niet bij de prijs inbegrepen voor bestellingen onder de <strong>€ 75,00</strong>. Wij behouden ons het recht voor om prijzen te wijzigen op basis van de huidige marktwaarde van retro-collectables.
                        </p>
                    </div>
                </div>

                <!-- Section 3 -->
                <div class="p-10 rounded-[2.5rem] border border-white/10 bg-white/5 backdrop-blur-xl relative group">
                    <div class="w-12 h-12 bg-[#d593ff]/20 rounded-xl flex items-center justify-center mb-6 text-[#d593ff] border border-[#d593ff]/30 font-orbitron text-lg font-bold">03</div>
                    <h2 class="font-barlow font-black text-3xl text-white uppercase mb-4 italic">Betaling</h2>
                    <p class="text-[#acaab1] leading-relaxed">
                        Betaling geschiedt vooraf via de aangeboden methoden (iDEAL, Klarna, Creditcard). Pas na ontvangst van de betaling wordt de order definitief verwerkt en verzonden.
                    </p>
                </div>

                <!-- Section 4 -->
                <div class="p-10 rounded-[2.5rem] border border-white/10 bg-white/5 backdrop-blur-xl relative group">
                    <div class="w-12 h-12 bg-[#d593ff]/20 rounded-xl flex items-center justify-center mb-6 text-[#d593ff] border border-[#d593ff]/30 font-orbitron text-lg font-bold">04</div>
                    <h2 class="font-barlow font-black text-3xl text-white uppercase mb-4 italic">Eigendom</h2>
                    <p class="text-[#acaab1] leading-relaxed">
                        Geleverde producten blijven eigendom van ABigBoysGame totdat het volledige orderbedrag is voldaan. Wij leveren uitsluitend aan particulieren en verzamelaars.
                    </p>
                </div>
            </div>

            <!-- Trust Bar -->
            <div class="p-8 rounded-3xl border border-dashed border-white/10 text-center">
                <p class="text-[#acaab1] text-sm uppercase tracking-widest font-orbitron">Vragen over deze voorwaarden? Neem contact op via onze support desk.</p>
            </div>
        </div>
    </div>
    <Footer />
</BaseLayout>


