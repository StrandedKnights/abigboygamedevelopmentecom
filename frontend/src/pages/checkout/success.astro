---
import BaseLayout from '../../layouts/BaseLayout.astro';
import prisma from '../../lib/prisma';

const orderId = Astro.url.searchParams.get('orderId');

let order = null;
if (orderId) {
    order = await prisma.order.findUnique({
        where: { id: orderId },
        include: { items: { include: { product: true } } }
    });
}
---

<BaseLayout title="Bedankt voor je bestelling! — A Big Boy's Game">
    <main class="min-h-screen bg-surface flex items-center justify-center p-4 py-20 relative overflow-hidden">
        <!-- Background Glow -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary/20 rounded-full blur-[120px] opacity-20 pointer-events-none"></div>

        <div class="max-w-2xl w-full bg-surface-container-high/40 border border-white/5 backdrop-blur-xl rounded-[40px] p-8 md:p-12 shadow-2xl relative z-10 text-center reveal-active">
            
            <!-- Success Icon -->
            <div class="w-24 h-24 bg-deal-green/10 border border-deal-green/20 rounded-full flex items-center justify-center mx-auto mb-8 relative">
                <span class="material-symbols-outlined text-deal-green text-5xl">check_circle</span>
                <div class="absolute inset-0 bg-deal-green/20 blur-2xl rounded-full scale-75"></div>
            </div>

            <h1 class="font-barlow font-black text-4xl md:text-5xl text-white uppercase tracking-tighter mb-4 italic">
                BEDANKT VOOR JE BESTELLING!
            </h1>
            
            <p class="text-on-surface-variant font-medium text-lg mb-10 max-w-md mx-auto">
                Je betaling is succesvol verwerkt. We gaan direct aan de slag om je pakketje klaar te maken voor verzending.
            </p>

            {order && (
                <div class="bg-black/20 border border-white/5 rounded-2xl p-6 mb-10 text-left">
                    <div class="flex justify-between items-center mb-4 border-b border-white/5 pb-2">
                        <span class="text-[10px] font-orbitron uppercase tracking-widest text-on-surface-variant">Order Nummer</span>
                        <span class="text-xs font-mono text-white">#{order.id.split('-')[0].toUpperCase()}</span>
                    </div>
                    
                    <ul class="space-y-4 mb-4">
                        {order.items.map(item => (
                            <li class="flex justify-between items-center">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-white/5 rounded-lg border border-white/5 overflow-hidden">
                                        <img src={item.product?.imageUrl || '/images/placeholder.jpg'} alt={item.product?.title} class="w-full h-full object-cover" />
                                    </div>
                                    <div>
                                        <div class="text-sm font-bold text-white line-clamp-1">{item.product?.title}</div>
                                        <div class="text-[10px] text-on-surface-variant">Aantal: {item.quantity}</div>
                                    </div>
                                </div>
                                <div class="text-sm font-barlow font-bold text-white italic">
                                    €{(item.priceAtPurchaseInCents * item.quantity / 100).toFixed(2)}
                                </div>
                            </li>
                        ))}
                    </ul>

                    <div class="flex justify-between items-center pt-2 border-t border-white/5 font-barlow font-black text-2xl text-deal-green italic uppercase italic">
                        <span>Totaal</span>
                        <span>€{(order.totalAmountInCents / 100).toFixed(2)}</span>
                    </div>
                </div>
            )}

            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a href="/shop" class="w-full sm:w-auto px-8 py-4 bg-primary text-on-primary font-orbitron text-sm font-black uppercase tracking-widest rounded-full hover:shadow-[0_0_20px_rgba(var(--primary-rgb),0.4)] transition-all">
                    Verder winkelen
                </a>
                <a href="/" class="w-full sm:w-auto px-8 py-4 bg-white/5 border border-white/10 text-white font-orbitron text-sm font-black uppercase tracking-widest rounded-full hover:bg-white/10 transition-all">
                    Terug naar Home
                </a>
            </div>

            <p class="mt-12 text-[10px] text-on-surface-variant/50 font-orbitron uppercase tracking-widest">
                Een bevestiging is verzonden naar <span class="text-white">{order?.customerEmail}</span>
            </p>
        </div>
    </main>
</BaseLayout>

<style>
    .bg-deal-green { background-color: #4ade80; }
    .text-deal-green { color: #4ade80; }
    .border-deal-green { border-color: #4ade80; }
</style>
