---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNavBar from '../components/TopNavBar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Checkout — A Big Boy's Game">
    <TopNavBar />
    
    <main class="max-w-7xl mx-auto px-6 py-12 lg:py-24 mt-16">
        <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">
            <!-- Left Column: Shipping & Contact -->
            <div class="lg:col-span-6 space-y-16">
                <!-- Section: Contactgegevens -->
                <section>
                    <h2 class="font-headline text-4xl uppercase tracking-wider mb-8 text-on-background">
                        Contactgegevens
                    </h2>
                    <div class="space-y-4">
                        <label class="block text-xs uppercase tracking-[0.2em] text-on-surface-variant font-medium ml-1">E-mailadres</label>
                        <input class="w-full bg-[#131319] border border-white/5 rounded-lg px-6 py-4 text-on-background focus:ring-2 focus:ring-[#d593ff]/50 outline-none transition-all duration-300 placeholder:text-outline/50" placeholder="jouw@email.nl" type="email"/>
                    </div>
                </section>

                <!-- Section: Verzendadres -->
                <section>
                    <h2 class="font-headline text-4xl uppercase tracking-wider mb-8 text-on-background">
                        Verzendadres
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-4">
                            <label class="block text-xs uppercase tracking-[0.2em] text-on-surface-variant font-medium ml-1">Voornaam</label>
                            <input class="w-full bg-[#131319] border border-white/5 rounded-lg px-6 py-4 text-on-background focus:ring-2 focus:ring-[#d593ff]/50 outline-none transition-all duration-300 placeholder:text-outline/50" placeholder="Voornaam" type="text"/>
                        </div>
                        <div class="space-y-4">
                            <label class="block text-xs uppercase tracking-[0.2em] text-on-surface-variant font-medium ml-1">Achternaam</label>
                            <input class="w-full bg-[#131319] border border-white/5 rounded-lg px-6 py-4 text-on-background focus:ring-2 focus:ring-[#d593ff]/50 outline-none transition-all duration-300 placeholder:text-outline/50" placeholder="Achternaam" type="text"/>
                        </div>
                        <div class="md:col-span-2 grid grid-cols-4 gap-6">
                            <div class="col-span-3 space-y-4">
                                <label class="block text-xs uppercase tracking-[0.2em] text-on-surface-variant font-medium ml-1">Straatnaam</label>
                                <input class="w-full bg-[#131319] border border-white/5 rounded-lg px-6 py-4 text-on-background focus:ring-2 focus:ring-[#d593ff]/50 outline-none transition-all duration-300 placeholder:text-outline/50" placeholder="Straatnaam" type="text"/>
                            </div>
                            <div class="col-span-1 space-y-4">
                                <label class="block text-xs uppercase tracking-[0.2em] text-on-surface-variant font-medium ml-1">Huisnr.</label>
                                <input class="w-full bg-[#131319] border border-white/5 rounded-lg px-6 py-4 text-on-background focus:ring-2 focus:ring-[#d593ff]/50 outline-none transition-all duration-300 placeholder:text-outline/50" placeholder="12A" type="text"/>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <label class="block text-xs uppercase tracking-[0.2em] text-on-surface-variant font-medium ml-1">Postcode</label>
                            <input class="w-full bg-[#131319] border border-white/5 rounded-lg px-6 py-4 text-on-background focus:ring-2 focus:ring-[#d593ff]/50 outline-none transition-all duration-300 placeholder:text-outline/50" placeholder="1234 AB" type="text"/>
                        </div>
                        <div class="space-y-4">
                            <label class="block text-xs uppercase tracking-[0.2em] text-on-surface-variant font-medium ml-1">Stad</label>
                            <input class="w-full bg-[#131319] border border-white/5 rounded-lg px-6 py-4 text-on-background focus:ring-2 focus:ring-[#d593ff]/50 outline-none transition-all duration-300 placeholder:text-outline/50" placeholder="Stad" type="text"/>
                        </div>
                    </div>
                </section>

                <!-- Trust Badges Desktop -->
                <div class="hidden lg:flex items-center gap-12 pt-12 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
                    <div class="flex items-center gap-2 font-headline text-lg tracking-widest text-[#d593ff] uppercase">
                        <span class="material-symbols-outlined">payments</span>
                        iDEAL
                    </div>
                    <div class="flex items-center gap-2 font-headline text-lg tracking-widest text-[#d593ff] uppercase">
                        <span class="material-symbols-outlined">credit_card</span>
                        Mastercard
                    </div>
                    <div class="flex items-center gap-2 font-headline text-lg tracking-widest text-on-surface-variant uppercase">
                        <span class="material-symbols-outlined text-deal-green" style="font-variation-settings: 'FILL' 1;">verified_user</span>
                        100% Veilig
                    </div>
                </div>
            </div>

            <!-- Right Column: Order Summary (40%) -->
            <div class="lg:col-span-4">
                <div class="bg-[#19191f]/50 backdrop-blur-xl sticky top-32 p-8 rounded-2xl border border-white/10 overflow-hidden shadow-2xl">
                    <!-- Glow background effect -->
                    <div class="absolute -top-24 -right-24 w-48 h-48 bg-[#d593ff]/10 blur-[80px] rounded-full pointer-events-none"></div>
                    
                    <h3 class="font-headline text-3xl uppercase tracking-wider mb-8 text-on-background flex justify-between items-baseline">
                        Overzicht
                        <span class="text-xs font-body font-normal tracking-normal text-on-surface-variant item-count">(0 items)</span>
                    </h3>

                    <!-- Order Items -->
                    <div id="checkout-items" class="space-y-8 mb-10 min-h-[100px] flex flex-col justify-center items-center border-2 border-dashed border-white/5 rounded-xl">
                        <div class="text-center opacity-40">
                             <span class="material-symbols-outlined text-4xl mb-2">production_quantity_limits</span>
                             <p class="font-headline text-lg uppercase tracking-widest">Winkelmand is leeg</p>
                        </div>
                    </div>

                    <!-- Totals -->
                    <div class="space-y-3 pt-6 border-t border-white/5 mb-8">
                        <div class="flex justify-between text-on-surface-variant font-medium">
                            <span>Subtotaal</span>
                            <span class="font-orbitron text-sm subtotaal-val">€ 0,00</span>
                        </div>
                        <div class="flex justify-between text-deal-green font-medium">
                            <span>Verzending</span>
                            <span class="font-headline tracking-widest uppercase">Gratis</span>
                        </div>
                        <div class="flex justify-between text-on-background text-2xl font-headline tracking-wider pt-4">
                            <span>Totaal</span>
                            <span class="font-orbitron totaal-val">€ 0,00</span>
                        </div>
                    </div>

                    <!-- CTA Button -->
                    <button class="w-full bg-deal-green text-[#0e0e13] font-orbitron font-black text-xl py-5 rounded-xl transition-all duration-300 transform active:scale-[0.98] flex items-center justify-center gap-3 shadow-[0_0_20px_rgba(0,255,136,0.3)] hover:shadow-[0_0_30px_rgba(0,255,136,0.5)]">
                        AFREKENEN
                        <span class="material-symbols-outlined text-background font-bold">arrow_forward</span>
                    </button>
                    <p class="text-center text-[10px] uppercase tracking-[0.2em] text-on-surface-variant mt-6">
                        Transacties worden veilig verwerkt
                    </p>
                </div>
            </div>
        </div>
    </main>
    
    <Footer />
</BaseLayout>


<script>
    import { CheckoutAPI } from '../services/apiClient';
    import { cartItems, clearCart } from '../store/cartStore';
    import { useStore } from '@nanostores/preact';

    const checkoutBtn = document.querySelector('button.bg-deal-green');
    const itemsContainer = document.getElementById('checkout-items');
    const subtotaalEl = document.querySelector('.subtotaal-val');
    const totaalEl = document.querySelector('.totaal-val');
    const countEl = document.querySelector('.item-count');

    // Sync cart with UI (simple vanilla for now to keep the Astro page clean)
    function renderItems() {
        const items = cartItems.get();
        if (!itemsContainer) return;
        
        if (items.length === 0) {
            itemsContainer.innerHTML = `
                <div class="text-center opacity-40 py-8">
                     <span class="material-symbols-outlined text-4xl mb-2">production_quantity_limits</span>
                     <p class="font-headline text-lg uppercase tracking-widest">Winkelmand is leeg</p>
                </div>`;
            return;
        }

        // Render real items
        itemsContainer.innerHTML = items.map(item => `
            <div class="flex gap-4 items-center w-full group">
                <div class="w-16 h-16 bg-[#131319] border border-white/5 rounded-lg p-2 overflow-hidden shrink-0">
                    <img src="${item.imageUrl}" alt="${item.title}" class="w-full h-full object-contain filter drop-shadow-md" />
                </div>
                <div class="flex-grow">
                    <h4 class="font-headline text-sm uppercase tracking-wider text-white line-clamp-1">${item.title}</h4>
                    <span class="text-[9px] uppercase tracking-widest text-[#acaab1] font-orbitron">${item.platform}</span>
                </div>
                <div class="font-orbitron text-xs text-white">
                    €${(item.priceInCents / 100).toFixed(2).replace('.', ',')}
                </div>
            </div>
        `).join('');

        // Update totals
        const totalCents = items.reduce((acc, item) => acc + item.priceInCents, 0);
        const formatted = `€ ${(totalCents / 100).toFixed(2).replace('.', ',')}`;
        if (subtotaalEl) subtotaalEl.textContent = formatted;
        if (totaalEl) totaalEl.textContent = formatted;
        if (countEl) countEl.textContent = `(${items.length} items)`;
    }

    renderItems();
    cartItems.subscribe(renderItems);

    checkoutBtn?.addEventListener('click', async () => {
        const items = cartItems.get();
        if (items.length === 0) {
            alert('Winkelmand is leeg.');
            return;
        }

        // Gather All Fields
        const email = (document.querySelector('input[type="email"]') as HTMLInputElement)?.value;
        const firstName = (document.querySelector('input[placeholder="Voornaam"]') as HTMLInputElement)?.value;
        const lastName = (document.querySelector('input[placeholder="Achternaam"]') as HTMLInputElement)?.value;
        const street = (document.querySelector('input[placeholder="Straatnaam"]') as HTMLInputElement)?.value;
        const houseNr = (document.querySelector('input[placeholder="12A"]') as HTMLInputElement)?.value;
        const postcode = (document.querySelector('input[placeholder="1234 AB"]') as HTMLInputElement)?.value;
        const city = (document.querySelector('input[placeholder="Stad"]') as HTMLInputElement)?.value;

        if (!email || !firstName || !lastName || !street || !postcode || !city) {
            alert('Vul a.u.b. alle adresgegevens in.');
            return;
        }

        const customerData = { 
            email, firstName, lastName, street, houseNr, postcode, city 
        };

        const cartPayload = items.map(i => ({ id: i.id, quantity: 1 }));

        try {
            checkoutBtn.textContent = 'DOORSTUREN NAAR MOLLIE...';
            (checkoutBtn as HTMLButtonElement).disabled = true;

            const response = await CheckoutAPI.createOrder(cartPayload, customerData);
            
            // Success response from API (wrapped in data by fetcher)
            if (response.paymentUrl) {
                // Clear cart before redirecting so they don't see it if they click "back"
                clearCart();
                window.location.href = response.paymentUrl;
            } else {
                throw new Error('No payment URL received');
            }
            
        } catch (error: any) {
            console.error('Checkout failed:', error);
            alert(`Fout bij afrekenen: ${error.message || 'Onbekende fout'}`);
            checkoutBtn.textContent = 'AFREKENEN';
            (checkoutBtn as HTMLButtonElement).disabled = false;
        }
    });
</script>

<style>
    input:focus {
        box-shadow: 0 0 15px rgba(155, 95, 224, 0.2);
    }
</style>
