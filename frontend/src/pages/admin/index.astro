---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabaseAdmin';

// Fetch key metrics on the server before rendering
let totalProducts = 0;
let totalOrders = 0;
let totalRevenue = 0;
let outOfStock = 0;

try {
  // 1. Total Products
  const { count: productCount } = await supabaseAdmin
    .from('Product')
    .select('*', { count: 'exact', head: true });
  totalProducts = productCount || 0;

  // 2. Out of Stock Products
  const { count: outOfStockCount } = await supabaseAdmin
    .from('Product')
    .select('*', { count: 'exact', head: true })
    .eq('inStock', false);
  outOfStock = outOfStockCount || 0;

  // 3. Orders & Revenue
  // Note: Depending on your schema, it might be named 'Order', 'Orders' etc. Let's assume 'Order'.
  // We'll wrap in try-catch in case it's not created yet.
  const { data: ordersData, error: ordersError } = await supabaseAdmin
    .from('Order')
    .select('totalAmount, status');
  
  if (!ordersError && ordersData) {
    totalOrders = ordersData.length;
    // Calculate revenue from PAID and SHIPPED orders
    totalRevenue = ordersData
        .filter(o => o.status !== 'PENDING')
        .reduce((sum, o) => sum + (Number(o.totalAmount) || 0), 0);
  }
} catch (e) {
  console.error("Failed to fetch admin metrics", e);
}
---

<AdminLayout title="Dashboard Overview">
   <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-10">
      
      <!-- Metric Card: Total Revenue -->
      <div class="bg-surface-container-high/40 border border-white/5 rounded-2xl p-6 relative overflow-hidden group">
         <div class="absolute inset-0 bg-gradient-to-br from-deal-green/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
         <div class="flex items-center justify-between mb-4">
            <h3 class="font-orbitron text-[10px] tracking-[0.2em] uppercase text-on-surface-variant">Totale Omzet</h3>
            <div class="w-8 h-8 rounded-full bg-deal-green/10 flex items-center justify-center text-deal-green">
               <span class="material-symbols-outlined text-[16px]">payments</span>
            </div>
         </div>
         <div class="flex items-baseline gap-2">
            <span class="font-barlow font-black text-4xl text-white">€{totalRevenue.toFixed(2)}</span>
         </div>
      </div>

      <!-- Metric Card: Total Orders -->
      <div class="bg-surface-container-high/40 border border-white/5 rounded-2xl p-6 relative overflow-hidden group">
         <div class="absolute inset-0 bg-gradient-to-br from-deal-purple/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
         <div class="flex items-center justify-between mb-4">
            <h3 class="font-orbitron text-[10px] tracking-[0.2em] uppercase text-on-surface-variant">Bestellingen</h3>
            <div class="w-8 h-8 rounded-full bg-deal-purple/10 flex items-center justify-center text-deal-purple">
               <span class="material-symbols-outlined text-[16px]">receipt_long</span>
            </div>
         </div>
         <div class="flex items-baseline gap-2">
            <span class="font-barlow font-black text-4xl text-white">{totalOrders}</span>
         </div>
      </div>

      <!-- Metric Card: Total Products -->
      <div class="bg-surface-container-high/40 border border-white/5 rounded-2xl p-6 relative overflow-hidden group">
         <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
         <div class="flex items-center justify-between mb-4">
            <h3 class="font-orbitron text-[10px] tracking-[0.2em] uppercase text-on-surface-variant">Actieve Producten</h3>
            <div class="w-8 h-8 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400">
               <span class="material-symbols-outlined text-[16px]">inventory_2</span>
            </div>
         </div>
         <div class="flex items-baseline gap-2">
            <span class="font-barlow font-black text-4xl text-white">{totalProducts - outOfStock}</span>
            <span class="text-xs text-on-surface-variant font-medium">/{totalProducts}</span>
         </div>
      </div>

      <!-- Metric Card: Out of Stock Alerts -->
      <div class="bg-surface-container-high/40 border border-[#ff4b4b]/20 rounded-2xl p-6 relative overflow-hidden group">
         <div class="absolute inset-0 bg-gradient-to-br from-[#ff4b4b]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
         <div class="flex items-center justify-between mb-4">
            <h3 class="font-orbitron text-[10px] tracking-[0.2em] uppercase text-[#ff4b4b]">Niet Leverbaar (Actie Vereist)</h3>
            <div class="w-8 h-8 rounded-full bg-[#ff4b4b]/10 flex items-center justify-center text-[#ff4b4b]">
               <span class="material-symbols-outlined text-[16px]">warning</span>
            </div>
         </div>
         <div class="flex items-baseline gap-2">
            <span class="font-barlow font-black text-4xl text-white">{outOfStock}</span>
         </div>
      </div>

   </div>

   <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Quick Actions -->
      <div class="bg-surface-container-high/20 border border-white/5 rounded-2xl p-8">
         <h2 class="font-barlow font-bold text-xl uppercase tracking-widest text-white mb-6">Snelle Acties</h2>
         <div class="space-y-4">
            <a href="/admin/products/new" class="flex items-center gap-4 p-4 rounded-xl bg-deal-green/10 border border-deal-green/20 hover:bg-deal-green/20 transition-colors group no-underline">
               <div class="w-10 h-10 rounded-lg bg-deal-green flex items-center justify-center text-black">
                  <span class="material-symbols-outlined">add</span>
               </div>
               <div>
                  <h4 class="font-orbitron text-sm font-bold tracking-wider text-white group-hover:text-deal-green transition-colors">Nieuw Product Toevoegen</h4>
                  <p class="text-xs text-on-surface-variant mt-1">Voeg direct een nieuwe game of console toe aan de catalogus.</p>
               </div>
            </a>
            <a href="/admin/orders" class="flex items-center gap-4 p-4 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors group no-underline">
               <div class="w-10 h-10 rounded-lg bg-surface-container focus items-center justify-center text-white flex">
                  <span class="material-symbols-outlined">local_shipping</span>
               </div>
               <div>
                  <h4 class="font-orbitron text-sm font-bold tracking-wider text-white">Bestellingen Verwerken</h4>
                  <p class="text-xs text-on-surface-variant mt-1">Bekijk en markeer vandaag de openstaande bestellingen als verzonden.</p>
               </div>
            </a>
         </div>
      </div>

      <!-- Welcome Info -->
        <div class="bg-surface-container-high/20 border border-white/5 rounded-2xl p-8 backdrop-blur-sm relative overflow-hidden">
            <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-deal-purple/20 blur-[100px] pointer-events-none"></div>
            <h2 class="font-barlow font-bold text-xl uppercase tracking-widest text-white mb-4">Systeem Status</h2>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-6">
                Welkom in het Secure Command Center van <strong>A Big Boy's Game</strong>. Het systeem draait momenteel via Astro SSR met directe database synchronisatie via Supabase.
            </p>
            <div class="space-y-3">
                <div class="flex items-center justify-between text-xs border-b border-white/5 pb-2">
                    <span class="text-on-surface-variant uppercase tracking-widest">Database Connectie</span>
                    <span class="flex items-center gap-1 text-deal-green font-bold"><span class="w-2 h-2 rounded-full bg-deal-green"></span> Online</span>
                </div>
                <div class="flex items-center justify-between text-xs border-b border-white/5 pb-2">
                    <span class="text-on-surface-variant uppercase tracking-widest">Afbeelding Opslag</span>
                    <span class="flex items-center gap-1 text-deal-green font-bold"><span class="w-2 h-2 rounded-full bg-deal-green"></span> Online</span>
                </div>
            </div>
        </div>
   </div>
</AdminLayout>
