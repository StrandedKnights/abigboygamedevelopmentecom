---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopNavBar from '../../components/TopNavBar.astro';
import Footer from '../../components/Footer.astro';
import { getProductById } from '../../lib/products';
import AddToCartBtn from '../../components/shop/AddToCartBtn';

const { id } = Astro.params;

if (!id) {
    return Astro.redirect('/404');
}

const product = await getProductById(id);

if (!product) {
    return Astro.redirect('/404');
}

const formattedPrice = (product.priceInCents / 100).toLocaleString('nl-NL', {
    style: 'currency',
    currency: 'EUR',
});

const getPlatformColor = (platform: string) => {
    if (platform.includes('PlayStation')) return '#3344ff';
    if (platform.includes('Nintendo')) return '#e60012';
    if (platform.includes('Xbox')) return '#107c10';
    return '#d593ff';
};

const platformColor = getPlatformColor(product.platform);
---

<BaseLayout title={`${product.title} - A Big Boy's Game`}>
    <TopNavBar />
    
    <main class="pt-32 pb-24 px-6 md:px-12 lg:px-24 max-w-[1600px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
            <!-- Left Column: Product Image -->
            <div class="lg:col-span-6 relative group">
                <div class="aspect-[4/5] lg:aspect-square rounded-xl overflow-hidden bg-surface-container shadow-[0_0_50px_rgba(213,147,255,0.15)] ring-1 ring-primary/10 relative">
                    <img 
                        src={product.imageUrl} 
                        alt={product.title}
                        class="w-full h-full object-contain p-4 transition-transform duration-700 group-hover:scale-105" 
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#0e0e13] via-transparent to-transparent opacity-60"></div>
                    <!-- Inner Glow Effect -->
                    <div class="absolute inset-0 pointer-events-none shadow-[inset_0_0_100px_rgba(213,147,255,0.1)]"></div>
                    
                    {/* Condition Badge on image */}
                    <div class="absolute top-6 left-6 font-primary text-[10px] font-black uppercase tracking-[0.2em] px-4 py-2 rounded-sm" 
                         style={`background: #00FF88; color: #000; box-shadow: 0 0 15px rgba(0,255,136,0.3);`}>
                        {product.condition}
                    </div>
                </div>
                <!-- Thumbnails/Gallery (Optional but enhances PDP feel) -->
                <div class="grid grid-cols-4 gap-4 mt-6">
                    <div class="aspect-square bg-surface-container rounded-lg border border-primary/20 p-2 cursor-pointer">
                        <img class="w-full h-full object-contain rounded-md" src={product.imageUrl} alt={product.title} />
                    </div>
                    <div class="aspect-square bg-surface-container rounded-lg border border-transparent hover:border-primary/20 p-2 cursor-pointer transition-colors flex justify-center items-center">
                        <span class="material-symbols-outlined text-primary/40">image</span>
                    </div>
                    <div class="aspect-square bg-surface-container rounded-lg border border-transparent hover:border-primary/20 p-2 cursor-pointer transition-colors flex justify-center items-center">
                         <span class="material-symbols-outlined text-primary/40">image</span>
                    </div>
                    <div class="aspect-square bg-surface-container-low rounded-lg flex items-center justify-center border border-outline-variant/10">
                        <span class="material-symbols-outlined text-primary/40">add_a_photo</span>
                    </div>
                </div>
            </div>

            <!-- Right Column: Product Info -->
            <div class="lg:col-span-6 flex flex-col space-y-8">
                <div class="space-y-4">
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-primary/10 border border-primary/20 text-primary font-label text-[10px] font-bold uppercase tracking-[0.2em] rounded-full" style={`color: ${platformColor}; border-color: ${platformColor}40; background: ${platformColor}15;`}>
                            {product.platform}
                        </span>
                        <span class="px-3 py-1 bg-primary/10 border border-primary/20 text-primary font-label text-[10px] font-bold uppercase tracking-[0.2em] rounded-full">
                            Condition: {product.condition}
                        </span>
                    </div>
                    <h1 class="text-4xl md:text-5xl lg:text-8xl font-headline font-extrabold tracking-tight text-on-surface leading-none">
                        {product.title}
                    </h1>
                    <div class="flex items-center gap-6">
                        <span class="text-5xl font-headline font-bold text-white tracking-tighter">{formattedPrice}</span>
                        {product.isWeekdeal && product.discountPriceInCents ? (
                            <span class="px-2 py-0.5 bg-deal-green/20 text-deal-green font-label text-[10px] font-bold uppercase border border-deal-green/30">
                                WEEKDEAL (-{Math.round(((product.priceInCents - product.discountPriceInCents)/product.priceInCents)*100)}%)
                            </span>
                        ) : product.priceInCents > 10000 ? (
                            <span class="px-2 py-0.5 bg-secondary-container/20 text-secondary-container font-label text-[10px] font-bold uppercase border border-secondary-container/30">
                                ZELDZAAM
                            </span>
                        ) : null}
                    </div>
                    {product.isWeekdeal && product.discountPriceInCents && (
                        <span class="font-orbitron text-lg text-[#76747b] line-through mt-1 block">
                            Van €{(product.priceInCents / 100).toFixed(2).replace('.', ',')}
                        </span>
                    )}
                </div>
                
                <div class="space-y-4">
                    <AddToCartBtn 
                        client:load 
                        product={{
                            id: product.id,
                            title: product.title,
                            priceInCents: product.isWeekdeal && product.discountPriceInCents ? product.discountPriceInCents : product.priceInCents,
                            imageUrl: product.imageUrl,
                            platform: product.platform,
                            stock: product.stock
                        }}
                        isAvailable={product.isAvailable}
                    />
                    <p class="text-center text-on-surface-variant text-xs font-label uppercase tracking-widest">
                        {product.isAvailable ? 'Op voorraad - Direct leverbaar' : 'Niet leverbaar - Uitverkocht'}
                    </p>
                </div>

                <!-- Trust Box -->
                <div class="glass-panel border border-outline-variant/10 rounded-xl p-6 space-y-6">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-lg bg-surface-container-high flex items-center justify-center border border-primary/20">
                            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">verified</span>
                        </div>
                        <div>
                            <p class="font-headline text-sm font-bold tracking-wide uppercase">Getest & Werkend</p>
                            <p class="text-on-surface-variant text-xs">100% garantie op alle retro hardware.</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-lg bg-surface-container-high flex items-center justify-center border border-primary/20">
                            <span class="material-symbols-outlined text-primary">payments</span>
                        </div>
                        <div>
                            <p class="font-headline text-sm font-bold tracking-wide uppercase">Veilig Betalen met iDEAL</p>
                            <p class="text-on-surface-variant text-xs">Versleutelde transacties via Mollie.</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-lg bg-surface-container-high flex items-center justify-center border border-primary/20">
                            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">schedule</span>
                        </div>
                        <div>
                            <p class="font-headline text-sm font-bold tracking-wide uppercase">15 Minuten Gereserveerd</p>
                            <p class="text-on-surface-variant text-xs">Product blijft in je mandje tijdens checkout.</p>
                        </div>
                    </div>
                </div>

                <!-- Product Description -->
                <div class="space-y-4 pt-4">
                    <h3 class="font-headline text-xs font-black tracking-widest text-primary uppercase">Product Informatie</h3>
                    <div class="text-on-surface-variant text-sm leading-relaxed space-y-4">
                        <p>Herbeleef de legende. Dit exemplaar is zorgvuldig gecontroleerd op kwaliteit en functionaliteit. Perfect voor de verzamelaar die alleen genoegen neemt met het beste voor zijn retro vault.</p>
                        <ul class="grid grid-cols-2 gap-y-2 font-label text-[10px] uppercase tracking-wider">
                            <li class="flex items-center gap-2"><span class="w-1 h-1 bg-primary rounded-full" style={`background: ${platformColor};`}></span> Platform: {product.platform}</li>
                            <li class="flex items-center gap-2"><span class="w-1 h-1 bg-primary rounded-full" style={`background: ${platformColor};`}></span> Conditie: {product.condition}</li>
                            <li class="flex items-center gap-2"><span class="w-1 h-1 bg-primary rounded-full" style={`background: ${platformColor};`}></span> Regio: PAL (NL/EU)</li>
                            <li class="flex items-center gap-2"><span class="w-1 h-1 bg-primary rounded-full" style={`background: ${platformColor};`}></span> Authenticiteit: Geverifieerd</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</BaseLayout>

<style>
    .glass-panel {
        background: rgba(31, 31, 36, 0.1);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
    }
    main {
        background-color: #131318;
    }
</style>
