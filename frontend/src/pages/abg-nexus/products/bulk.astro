---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminBulkForm from '../../../components/admin/AdminBulkForm';
import prisma from '../../../lib/prisma';

// Fetch all editable products
const productsResponse = await prisma.product.findMany({
    select: {
        id: true,
        title: true,
        platform: true,
        stock: true,
        priceInCents: true,
        purchasePriceInCents: true,
        taxScheme: true
    },
    orderBy: { createdAt: 'desc' }
});
---

<AdminLayout title="Magazijn Bulk Update">
    <div class="mb-8">
        <a href="/abg-nexus/products" class="text-on-surface-variant hover:text-deal-green flex items-center gap-2 text-[10px] font-orbitron font-bold uppercase tracking-[0.2em] no-underline transition-colors w-fit mb-4">
            <span class="material-symbols-outlined text-sm">arrow_back</span> Terug naar overzicht
        </a>
        <h2 class="font-barlow font-black text-3xl uppercase tracking-widest text-white mb-2">Bulk Inventaris Update</h2>
        <p class="text-on-surface-variant text-sm font-medium">Pas snel inkoopprijzen, verkoopprijzen en voorraad aan voor de hele categorie.</p>
    </div>

    <div class="bg-surface-container-high/40 border border-white/5 rounded-2xl backdrop-blur-md overflow-hidden relative">
        <div class="p-6 overflow-x-auto custom-scrollbar">
            <AdminBulkForm client:load initialProducts={productsResponse as any} />
        </div>
    </div>
    <style is:inline>
        .custom-scrollbar::-webkit-scrollbar { height: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }
    </style>
</AdminLayout>
