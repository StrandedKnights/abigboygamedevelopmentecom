generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                    String      @id @default(cuid())
  title                 String
  platform              String
  priceInCents          Int
  purchasePriceInCents  Int?
  stock                 Int
  condition             String
  imageUrl              String
  isLegacy              Boolean     @default(false)
  isWeekdeal            Boolean     @default(false)
  discountPriceInCents  Int?
  reservedUntil         DateTime?
  taxScheme             String      @default("MARGIN")
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  orderItems            OrderItem[]
}

model Order {
  id                 String      @id @default(cuid())
  customerEmail      String
  customerName       String
  totalAmountInCents Int
  molliePaymentId    String?     @unique
  status             String      @default("PENDING")
  trackingCode       String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  items              OrderItem[]
  events             OrderEvent[]
}

model OrderItem {
  id                     String  @id @default(cuid())
  quantity                       Int
  priceAtPurchaseInCents         Int
  purchasePriceAtPurchaseInCents Int?
  
  orderId                        String
  order                  Order   @relation(fields: [orderId], references: [id])
  
  productId              String
  taxScheme              String  @default("MARGIN")
  product                Product @relation(fields: [productId], references: [id])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  type      String
  details   String
  createdAt DateTime @default(now())
}
