# ============================================================
#  A Big Boy's Game — Environment Configuration
#  Copy this file to `.env` and fill in the values.
# ============================================================

# ──────────────────────────────────
#  DATABASE (Prisma / PostgreSQL via Supabase)
# ──────────────────────────────────
# Connection pooling URL (for Prisma client)
DATABASE_URL="postgresql://postgres:[YOUR_DB_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres"
# Direct connection URL (for Prisma migrations)
DIRECT_URL="postgresql://postgres:[YOUR_DB_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres"

# ──────────────────────────────────
#  SUPABASE (Auth + Storage)
# ──────────────────────────────────
# Public Supabase project URL (used client-side and server-side)
PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"

# Publishable / Anon key (safe for client-side use)
PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_KEY="sb_publishable_..."

# Service Role Key (server-side only — NEVER expose to client)
# Used by supabaseAdmin.ts for privileged operations (image uploads, etc.)
SUPABASE_SERVICE_KEY="sbp_..."

# ──────────────────────────────────
#  PAYMENTS (Mollie)
# ──────────────────────────────────
# Mollie API key (test_ prefix for sandbox, live_ prefix for production)
MOLLIE_API_KEY="test_..."

# ──────────────────────────────────
#  APPLICATION URLS
# ──────────────────────────────────
# The public-facing URL of the frontend
FRONTEND_URL="http://localhost:4321"
# Webhook callback URL (must be publicly accessible — use ngrok for local dev)
NGROK_URL="https://your-tunnel.ngrok.io"
# API URL override (only needed if API is on a different domain than frontend)
PUBLIC_API_URL="http://localhost:4321/api"

# ──────────────────────────────────
#  ADMIN SECURITY
# ──────────────────────────────────
# Gateway key for accessing admin panel (obscurity layer).
# Generate a strong random key: `node -e "console.log(crypto.randomUUID())"`
# Access admin via: /admin?key=YOUR_KEY_HERE
ADMIN_GATEWAY_KEY=""
