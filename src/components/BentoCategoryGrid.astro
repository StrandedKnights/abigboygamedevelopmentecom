<!-- Bento Grid Categories -->
<section class="container mx-auto px-6 py-24 relative z-20">
<div class="flex items-center gap-4 mb-12">
<span class="material-symbols-outlined text-primary text-3xl">category</span>
<h2 class="font-orbitron text-3xl font-bold text-on-surface uppercase tracking-wider">
                    Collectie Verkennen
                </h2>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 h-auto md:h-[600px]">
<!-- Bento Item 1: Large -->
<a class="relative group block overflow-hidden rounded-xl bg-surface-container-high border border-outline-variant/30 md:col-span-2 md:row-span-2 transition-transform hover:-translate-y-1" href="#consoles">
<img alt="Retro Consoles" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-75 transition-opacity duration-500 group-hover:scale-105" data-alt="Classic video game console illuminated in low light with neon purple and blue reflections" src="https://lh3.googleusercontent.com/aida-public/I-4kF78J3a-Z-w_eB8Qe5i7yN2x-n9S6J4vRbA2q-M5v7QhJ8Xm8wO9D7U--zP9U9v0QZ0t1n4L6I8a9N2K4mF1qO-H1S-1T9b7R9bZ8R9z8L3C0lU5vD-x4k6mR-jW8sD-y9L2Z8N0V7aA-E1V-o3k2gJ-pP5Z8L9R8VQRB9l6vOqZ0pI2oE3vFp0bA-X8x2gM-hL9L8vH7U-r6K1iL8tW6vI9T-jN8V8V8L0D-_"/>
<div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/40 to-transparent"></div>
<div class="absolute bottom-0 left-0 p-8 space-y-2">
<h3 class="font-orbitron text-2xl font-bold text-on-surface">CONSOLES</h3>
<p class="font-space-grotesk text-on-surface-variant font-light group-hover:text-primary transition-colors">
                            Van Atari tot PS3, vind de hardware van je dromen.
                        </p>
</div>
<div class="absolute top-6 right-6">
<span class="material-symbols-outlined text-on-surface/50 group-hover:text-primary transition-colors">arrow_forward</span>
</div>
</a>
<!-- Bento Item 2: Small -->
<a class="relative group block overflow-hidden rounded-xl bg-surface-container border border-outline-variant/50 transition-transform hover:-translate-y-1" href="#games">
<img alt="Retro Games" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity duration-500 group-hover:scale-105" data-alt="Stacks of colorful, vintage video game cartridges with glowing edges" src="https://lh3.googleusercontent.com/aida-public/O4n5i7v7m1zL9Q-O7a-L5s5T1a-X1m5L9T-A5k9x7j4Z-eC-P6D-M5pD9Y0P8F8e0O4P8y4P4e4y0F-Q8Z8Q0M4E-q0O8k5P7R9P9v4O9A4M8B9P-a9P-v4A1x0L0G0g5P7N7J0q0u-w_F0A4I8X9M-q9Q9rQ7r2o2qI-Z7S5G1b9E3nE2L7gI-_"/>
<div class="absolute inset-0 bg-gradient-to-t from-surface-variant/90 to-transparent"></div>
<div class="absolute bottom-0 left-0 p-6">
<h3 class="font-orbitron shadow-surface/20 text-xl font-bold text-on-surface">GAMES</h3>
<span class="inline-block mt-2 text-xs font-inter uppercase tracking-wider text-primary border border-primary/40 px-2 py-1 rounded-sm bg-primary/10">Nieuw Binnen</span>
</div>
</a>
<!-- Bento Item 3: Small -->
<a class="relative group block overflow-hidden rounded-xl bg-surface-container border border-outline-variant/50 transition-transform hover:-translate-y-1" href="#merch">
<img alt="Retro Merch" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity duration-500 group-hover:scale-105" data-alt="Collection of nostalgic, slightly worn retro gaming merchandise illuminated with ambient light" src="https://lh3.googleusercontent.com/aida-public/Y0rQ8u8Q-S9T4-Z7g5A-vP7n9I9g1A-_1X7T7O4x4k7z-F7K-mX4Q9L4Y0T9T4G9J9M9Z9g4X-G4L4k4N4v-m-I5k5yQ9oQ1Z-_7Q1Y9K4jQ1yI8e8k9J9Z5i7N7T4x4M4zO4zL-E3aI1vK9H8sO8lI8uL_h5gO1zK0W-iG-D8T7X6Z0y1L-_"/>
<div class="absolute inset-0 bg-gradient-to-t from-surface-variant/90 to-transparent"></div>
<div class="absolute bottom-0 left-0 p-6">
<h3 class="font-orbitron shadow-surface/20 text-xl font-bold text-on-surface">MERCHANDISE</h3>
<p class="font-space-grotesk text-sm text-on-surface-variant mt-1">Kleding &amp; Accessoires</p>
</div>
</a>
</div>
</section>
