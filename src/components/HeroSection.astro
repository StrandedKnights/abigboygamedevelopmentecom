<section class="relative min-h-[560px] pt-[64px] flex items-center overflow-hidden bg-[radial-gradient(circle_at_center,_#6A0DAD_0%,_#0A0A0F_70%)]">
<div class="absolute inset-0 scanline-overlay z-10 opacity-30"></div>
<div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 items-center gap-12 relative z-20">
<div class="space-y-6">
<h1 class="font-orbitron text-5xl md:text-7xl font-black text-on-surface leading-tight tracking-tighter">
                    JOUW RETRO <br/>
<span class="text-primary drop-shadow-[0_0_15px_rgba(213,147,255,0.4)]">GAMING PARADIJS</span>
</h1>
<p class="text-on-surface-variant text-lg max-w-lg font-body leading-relaxed">
                    Herbeleef de gouden jaren van gaming. Van zeldzame NES-cartridges tot legendarische PlayStation-klassiekers, wij hebben de schatten uit jouw jeugd.
                </p>
<div class="flex flex-wrap gap-4">
<button class="bg-gradient-to-r from-primary to-primary-container text-on-primary-container font-orbitron font-bold py-4 px-8 rounded-sm neon-glow transform hover:scale-105 transition-all uppercase tracking-widest text-sm">
                        Bekijk Aanbod
                    </button>
<button class="border border-outline-variant/40 bg-surface-container-high/50 backdrop-blur-sm text-on-surface font-orbitron font-bold py-4 px-8 rounded-sm hover:bg-surface-variant transition-all uppercase tracking-widest text-sm">
                        Inruilen
                    </button>
</div>
</div>
<div class="hidden lg:block relative group">
<div class="absolute -inset-4 bg-primary/20 rounded-full blur-3xl animate-pulse"></div>
<img alt="Retro Mascot" class="relative z-10 w-full max-w-md mx-auto drop-shadow-[0_0_50px_rgba(191,95,255,0.4)]" data-alt="Retro gaming mascot character or high-tech neon console setup with vibrant purple glowing highlights and floating digital artifacts" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCePtqVt2364tDZ7qMHJ0DOUBVHBR9FHl9x2jg89SpgrXdS5VP6bqaPaBOqi3nB4onNLZe0jJamiTDYh9OCnSc-DlKAS4-gBOoFoLkC7NXznmus84RUEHWVwyeXFxIVD87ZJBhV-3BTtUbxHeTVjeatJbmvBIGcktfwrV8kag1JJ-8pjxFSlO6ezVh-hiUxaSWG1oANsuc17r7Za54cyv2JheBJqDOMCjxKcYV-jfELzInGsgAnezLIzqnsFcbqFK5P5Yopw4UaLbo"/>
</div>
</div>
<!-- Scrolling Ticker -->
<div class="absolute bottom-0 w-full bg-surface-container-lowest/80 backdrop-blur-sm border-y border-primary/20 py-3 overflow-hidden z-30">
<div class="ticker-scroll flex items-center gap-12 font-orbitron text-sm font-bold text-primary-dim tracking-[0.3em]">
<span>NES · SNES · N64 · PS1 · PS2 · XBOX · SEGA · GAMEBOY · ATARI · DREAMCAST · GAME CUBE · WII · NEO GEO · COMMODORE 64</span>
<span>NES · SNES · N64 · PS1 · PS2 · XBOX · SEGA · GAMEBOY · ATARI · DREAMCAST · GAME CUBE · WII · NEO GEO · COMMODORE 64</span>
</div>
</div>
</section>
