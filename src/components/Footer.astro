---
---
<!-- Footer -->
<footer class="bg-surface-container-lowest border-t border-outline-variant/20 pt-16 pb-8 mt-24 relative z-20">
<div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12">
<!-- Brand col -->
<div class="col-span-1 md:col-span-1 space-y-4">
<h2 class="font-orbitron text-2xl font-black tracking-tight text-on-surface">
                    A BIG BOY'S<br/><span class="text-primary">GAME</span>
</h2>
<p class="font-space-grotesk text-sm text-on-surface-variant mt-4">
                    Jouw portaal naar het verleden. Retro games, consoles en toebehoren.
                </p>
<div class="flex gap-4 pt-4">
<a aria-label="Facebook" class="w-8 h-8 rounded-full bg-surface-container flex items-center justify-center text-primary-dim hover:text-primary hover:bg-surface-container-high transition-colors" href="#">
<span class="material-symbols-outlined text-lg">facebook</span>
</a>
<a aria-label="Instagram" class="w-8 h-8 rounded-full bg-surface-container flex items-center justify-center text-primary-dim hover:text-primary hover:bg-surface-container-high transition-colors" href="#">
<span class="material-symbols-outlined text-lg">photo_camera</span>
</a>
<a aria-label="Twitter" class="w-8 h-8 rounded-full bg-surface-container flex items-center justify-center text-primary-dim hover:text-primary hover:bg-surface-container-high transition-colors" href="#">
<span class="material-symbols-outlined text-lg">tag</span>
</a>
</div>
</div>
<!-- Links col 1 -->
<div>
<h3 class="font-orbitron font-bold text-on-surface mb-6 uppercase tracking-wider text-sm">Shop</h3>
<ul class="space-y-3 font-inter text-sm text-on-surface-variant">
<li><a class="hover:text-primary transition-colors" href="#">Nieuw Binnen</a></li>
<li><a class="hover:text-primary transition-colors" href="#">Consoles</a></li>
<li><a class="hover:text-primary transition-colors" href="#">Games</a></li>
<li><a class="hover:text-primary transition-colors" href="#">Accessoires</a></li>
<li><a class="hover:text-primary transition-colors" href="#">Aanbiedingen</a></li>
</ul>
</div>
<!-- Links col 2 -->
<div>
<h3 class="font-orbitron font-bold text-on-surface mb-6 uppercase tracking-wider text-sm">Informatie</h3>
<ul class="space-y-3 font-inter text-sm text-on-surface-variant">
<li><a class="hover:text-primary transition-colors" href="#">Over Ons</a></li>
<li><a class="hover:text-primary transition-colors" href="#">Inruilen &amp; Verkopen</a></li>
<li><a class="hover:text-primary transition-colors" href="#">Zeldzaamheid Gids</a></li>
<li><a class="hover:text-primary transition-colors" href="#">Garantie &amp; Retour</a></li>
<li><a class="hover:text-primary transition-colors" href="#">FAQ</a></li>
</ul>
</div>
<!-- Newsletter col -->
<div>
<h3 class="font-orbitron font-bold text-on-surface mb-6 uppercase tracking-wider text-sm">Nieuwsbrief</h3>
<p class="font-inter text-sm text-on-surface-variant mb-4">Schrijf je in voor exclusieve drops en geheime cheat codes (kortingen).</p>
<form class="flex flex-col gap-2">
<input class="w-full bg-surface border border-outline-variant/40 rounded-sm px-4 py-2 font-inter text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="Jouw emailadres" type="email"/>
<button class="w-full bg-primary/20 hover:bg-primary/30 text-primary border border-primary/40 font-orbitron font-bold py-2 rounded-sm transition-colors uppercase text-sm tracking-wider" type="submit">
                        Ontvang Loot
                    </button>
</form>
</div>
</div>
<div class="container mx-auto px-6 mt-16 pt-8 border-t border-outline-variant/10 flex flex-col md:flex-row justify-between items-center gap-4">
<p class="font-inter text-xs text-on-surface-variant/70">
                © 2024 A Big Boy's Game. Alle rechten voorbehouden.
            </p>
<div class="flex gap-4 font-inter text-xs text-on-surface-variant/70">
<a class="hover:text-on-surface transition-colors" href="#">Privacy Policy</a>
<a class="hover:text-on-surface transition-colors" href="#">Algemene Voorwaarden</a>
</div>
</div>
</footer>
